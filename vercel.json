{
    "functions": {
        "api/index.js": {
            "includeFiles": "views/**"
        }
    },
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/css/(.*)",
            "destination": "/public/css/$1"
        },
        {
            "source": "/js/(.*)",
            "destination": "/public/js/$1"
        },
        {
            "source": "/images/(.*)",
            "destination": "/public/images/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.js"
        }
    ]
}