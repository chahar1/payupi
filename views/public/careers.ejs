<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
        <title>Careers - Paybilupi</title>
</head>

<body class="bg-mesh font-outfit d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom border-light py-3">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <div class="bg-primary bg-gradient text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm"
                    style="width: 36px; height: 36px;">
                    <i class="fi fi-rr-wallet fs-5 mt-1"></i>
                </div>
                <span class="fw-bold fs-4 tracking-tight text-main">Paybilupi</span>
            </a>
            <div class="d-flex align-items-center gap-3">
                <a href="/auth/login" class="btn btn-alt px-4 rounded-pill fw-semibold shadow-sm d-none d-sm-block">Sign
                    In</a>
                <a href="/auth/register" class="btn btn-premium px-4 rounded-pill fw-semibold shadow-sm">Get Started</a>
            </div>
        </div>
    </nav>

    <div class="container py-5 my-5 flex-grow-1">
        <div class="row justify-content-center mb-5 pb-3">
            <div class="col-lg-8 text-center" data-aos="fade-up">
                <h1 class="display-4 fw-bold text-main mb-4">Build the Future of Finance</h1>
                <p class="fs-5 text-muted" style="line-height: 1.8;">We are a team of builders, designers, and problem
                    solvers working to make digital commerce universally accessible. If you love solving hard technical
                    challenges with massive real-world impact, you belong here.</p>
            </div>
        </div>

        <div class="row g-4 mb-5 pb-4">
            <div class="col-md-3" data-aos="fade-up" data-aos-delay="100">
                <div class="text-center p-3">
                    <i class="fi fi-rr-home-location text-primary fs-1 mb-3"></i>
                    <h5 class="fw-bold text-main">Work Anywhere</h5>
                    <p class="text-muted small">We are a fully distributed, remote-first team. Work from wherever you
                        are happiest and most productive.</p>
                </div>
            </div>
            <div class="col-md-3" data-aos="fade-up" data-aos-delay="200">
                <div class="text-center p-3">
                    <i class="fi fi-rr-gym text-success fs-1 mb-3"></i>
                    <h5 class="fw-bold text-main">Comprehensive Health</h5>
                    <p class="text-muted small">Top-tier medical, dental, and vision insurance for you and your
                        dependents.</p>
                </div>
            </div>
            <div class="col-md-3" data-aos="fade-up" data-aos-delay="300">
                <div class="text-center p-3">
                    <i class="fi fi-rr-graduation-cap text-warning fs-1 mb-3"></i>
                    <h5 class="fw-bold text-main">Continuous Learning</h5>
                    <p class="text-muted small">Annual stipend for books, courses, conferences, and continuous
                        professional development.</p>
                </div>
            </div>
            <div class="col-md-3" data-aos="fade-up" data-aos-delay="400">
                <div class="text-center p-3">
                    <i class="fi fi-rr-umbrella text-info fs-1 mb-3"></i>
                    <h5 class="fw-bold text-main">Unlimited PTO</h5>
                    <p class="text-muted small">We hire adults and trust them. Take the time you need to rest, recharge,
                        and travel.</p>
                </div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-9">
                <h3 class="fw-bold text-main mb-4">Open Positions</h3>

                <div
                    class="premium-card p-4 mb-3 hover-scale transition-all d-flex justify-content-between align-items-center cursor-pointer">
                    <div>
                        <h5 class="fw-bold text-main mb-1">Senior Node.js Backend Engineer</h5>
                        <p class="text-muted small mb-0"><i class="fi fi-rr-marker me-1"></i> Remote (India) • Full Time
                        </p>
                    </div>
                    <a href="#" class="btn btn-alt rounded-pill px-4">Apply <i
                            class="fi fi-rr-arrow-right ms-2"></i></a>
                </div>

                <div
                    class="premium-card p-4 mb-3 hover-scale transition-all d-flex justify-content-between align-items-center cursor-pointer">
                    <div>
                        <h5 class="fw-bold text-main mb-1">Product Designer (UI/UX)</h5>
                        <p class="text-muted small mb-0"><i class="fi fi-rr-marker me-1"></i> Remote (Global) • Full
                            Time</p>
                    </div>
                    <a href="#" class="btn btn-alt rounded-pill px-4">Apply <i
                            class="fi fi-rr-arrow-right ms-2"></i></a>
                </div>

                <div
                    class="premium-card p-4 mb-3 hover-scale transition-all d-flex justify-content-between align-items-center cursor-pointer">
                    <div>
                        <h5 class="fw-bold text-main mb-1">Developer Advocate</h5>
                        <p class="text-muted small mb-0"><i class="fi fi-rr-marker me-1"></i> Remote (India) • Full Time
                        </p>
                    </div>
                    <a href="#" class="btn btn-alt rounded-pill px-4">Apply <i
                            class="fi fi-rr-arrow-right ms-2"></i></a>
                </div>

                <div
                    class="premium-card p-4 mb-3 hover-scale transition-all d-flex justify-content-between align-items-center cursor-pointer">
                    <div>
                        <h5 class="fw-bold text-main mb-1">Customer Success Manager</h5>
                        <p class="text-muted small mb-0"><i class="fi fi-rr-marker me-1"></i> Bangalore, India • Full
                            Time</p>
                    </div>
                    <a href="#" class="btn btn-alt rounded-pill px-4">Apply <i
                            class="fi fi-rr-arrow-right ms-2"></i></a>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
</body>

</html>