<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
        <title>Contact Us - Paybilupi</title>
</head>

<body class="bg-mesh font-outfit d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom border-light py-3">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <div class="bg-primary bg-gradient text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm"
                    style="width: 36px; height: 36px;">
                    <i class="fi fi-rr-wallet fs-5 mt-1"></i>
                </div>
                <span class="fw-bold fs-4 tracking-tight text-main">Paybilupi</span>
            </a>
            <div class="d-flex align-items-center gap-3">
                <a href="/auth/login" class="btn btn-alt px-4 rounded-pill fw-semibold shadow-sm d-none d-sm-block">Sign
                    In</a>
                <a href="/auth/register" class="btn btn-premium px-4 rounded-pill fw-semibold shadow-sm">Get Started</a>
            </div>
        </div>
    </nav>

    <div class="container py-5 my-5 flex-grow-1">
        <div class="row justify-content-center mb-5 pb-3">
            <div class="col-lg-8 text-center" data-aos="fade-up">
                <h1 class="display-4 fw-bold text-main mb-4">Get in Touch</h1>
                <p class="fs-5 text-muted" style="line-height: 1.8;">Whether you have a technical question about our
                    API, need help scaling your integration, or simply want to learn more about our enterprise plans,
                    our dedicated team is ready to assist you.</p>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                <div class="premium-card p-4 h-100 text-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4"
                        style="width: 64px; height: 64px;">
                        <i class="fi fi-rr-headset fs-3"></i>
                    </div>
                    <h5 class="fw-bold text-main mb-3">Merchant Support</h5>
                    <p class="text-muted small mb-4">For immediate assistance with your account, transactions, or
                        gateway connections.</p>
                    <a href="mailto:support@paybilupi.com"
                        class="fw-bold text-primary text-decoration-none d-block">support@paybilupi.com</a>
                    <span class="small text-muted d-block mt-2">Response time: &lt; 2 hours</span>
                </div>
            </div>

            <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                <div class="premium-card p-4 h-100 text-center">
                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4"
                        style="width: 64px; height: 64px;">
                        <i class="fi fi-rr-code-branch fs-3"></i>
                    </div>
                    <h5 class="fw-bold text-main mb-3">Developer Integration</h5>
                    <p class="text-muted small mb-4">For technical inquiries regarding our SDKs, REST API parameters,
                        and environment setups.</p>
                    <a href="mailto:api-engineering@paybilupi.com"
                        class="fw-bold text-success text-decoration-none d-block">api-engineers@paybilupi.com</a>
                    <span class="small text-muted d-block mt-2">Response time: ~ 4 hours</span>
                </div>
            </div>

            <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                <div class="premium-card p-4 h-100 text-center">
                    <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4"
                        style="width: 64px; height: 64px;">
                        <i class="fi fi-rr-briefcase fs-3"></i>
                    </div>
                    <h5 class="fw-bold text-main mb-3">Enterprise Sales</h5>
                    <p class="text-muted small mb-4">Looking to process over ₹10,000,000 per month? Let's discuss a
                        custom SLA and priority routing.</p>
                    <a href="mailto:enterprise@paybilupi.com"
                        class="fw-bold text-warning text-decoration-none d-block">enterprise@paybilupi.com</a>
                    <span class="small text-muted d-block mt-2">Response time: Same business day</span>
                </div>
            </div>
        </div>

        <div class="row pt-4 border-top border-light">
            <div class="col-lg-6" data-aos="fade-right">
                <h4 class="fw-bold text-main mb-4">Headquarters</h4>
                <div class="d-flex align-items-start gap-3 mb-4">
                    <i class="fi fi-rr-marker text-primary fs-5 mt-1"></i>
                    <div>
                        <h6 class="fw-bold text-main mb-1">Bangalore Hub</h6>
                        <p class="text-muted small mb-0">9th Floor, Innovation Tower<br>Koramangala 4th
                            Block<br>Bengaluru, Karnataka 560034<br>India</p>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <i class="fi fi-rr-clock text-primary fs-5"></i>
                    <div>
                        <h6 class="fw-bold text-main mb-1">Business Hours</h6>
                        <p class="text-muted small mb-0">Monday – Friday: 9:00 AM to 6:00 PM IST</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mt-5 mt-lg-0" data-aos="fade-left">
                <div
                    class="premium-card p-4 bg-light text-center border-0 border-start border-primary border-4 h-100 d-flex flex-column justify-content-center">
                    <h5 class="fw-bold text-main mb-3">Notice to Partners</h5>
                    <p class="text-muted small mb-0">To ensure the fastest resolution times, we strongly request all
                        technical and account-related disputes be submitted via the <a href="/auth/dashboard"
                            class="fw-bold text-primary text-decoration-none">Merchant Dashboard</a> secure ticketing
                        system rather than direct email. Phone support is restricted exclusively to Enterprise SLA
                        clients.</p>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
</body>

</html>