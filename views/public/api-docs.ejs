<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
        <title>API Reference | Paybilupi Documentation</title>
        <!-- Prism.js for code highlighting -->
        <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css"
            rel="stylesheet" />
        <script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
        <style>
            :root {
                --docs-sidebar-width: 260px;
                --docs-code-width: 45%;
                --docs-primary: #4f46e5;
                --docs-bg: #ffffff;
                --docs-code-bg: #0f172a;
                --docs-border: #f1f5f9;
                --docs-text: #334155;
                --docs-header-height: 64px;
            }

            body {
                background-color: var(--docs-bg);
                color: var(--docs-text);
                font-family: 'Inter', -apple-system, sans-serif;
                overflow-x: hidden;
            }

            /* 3-Column Layout */
            .docs-container {
                display: flex;
                min-height: 100vh;
            }

            /* Sidebar (Left) */
            .docs-sidebar {
                width: var(--docs-sidebar-width);
                height: 100vh;
                position: fixed;
                left: 0;
                top: 0;
                background: #0A0636;
                border-right: 1px solid var(--docs-border);
                padding: 1.5rem 1rem;
                overflow-y: auto;
                z-index: 1000;
                display: flex;
                flex-direction: column;
            }

            /* Main Content Area (Center + Right) */
            .docs-main {
                flex: 1;
                margin-left: var(--docs-sidebar-width);
                display: flex;
            }

            /* Technical Content (Center) */
            .docs-content {
                flex: 1;
                padding: 4rem 3rem;
                max-width: 800px;
            }

            /* Code Samples (Right) */
            .docs-code-panel {
                width: var(--docs-code-width);
                background: var(--docs-code-bg);
                position: sticky;
                top: 0;
                height: 100vh;
                overflow-y: auto;
                padding: 2rem;
                color: #fff;
            }

            /* Sidebar Styling */
            .sidebar-nav {
                list-style: none;
                padding: 0;
                margin: 0;
            }

            .sidebar-heading {
                font-size: 0.65rem;
                font-weight: 800;
                color: #94a3b8;
                text-transform: uppercase;
                margin: 2rem 0 0.75rem 0.75rem;
                letter-spacing: 0.1em;
            }

            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 0.65rem 1rem;
                color: #64748b;
                text-decoration: none;
                font-size: 0.9rem;
                font-weight: 500;
                border-radius: 10px;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                position: relative;
                margin-bottom: 2px;
            }

            .sidebar-link i {
                font-size: 1rem;
                color: #94a3b8;
                transition: all 0.3s;
            }

            .sidebar-link:hover {
                background: #f8fafc;
                color: var(--docs-primary);
            }

            .sidebar-link:hover i {
                color: var(--docs-primary);
                transform: translateX(2px);
            }

            .sidebar-link.active {
                background: rgba(79, 70, 229, 0.06);
                color: var(--docs-primary);
                font-weight: 600;
            }

            .sidebar-link.active i {
                color: var(--docs-primary);
            }

            .sidebar-link.active::before {
                content: '';
                position: absolute;
                left: -4px;
                top: 20%;
                height: 60%;
                width: 4px;
                background: var(--docs-primary);
                border-radius: 0 4px 4px 0;
            }

            /* Search Bar Placeholder */
            .sidebar-search {
                position: relative;
                margin-bottom: 1.5rem;
                padding: 0 0.5rem;
            }

            .sidebar-search input {
                width: 100%;
                background: #012952;
                border: 1px solid transparent;
                border-radius: 10px;
                padding: 0.6rem 1rem 0.6rem 2.5rem;
                font-size: 0.85rem;
                color: #1e293b;
                transition: all 0.2s;
            }

            .sidebar-search input:focus {
                outline: none;
                background: #fff;
                border-color: var(--docs-primary);
                box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
            }

            .sidebar-search i {
                position: absolute;
                left: 1.25rem;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                font-size: 0.9rem;
            }

            /* Content Styling */
            h1 {
                font-size: 2.5rem;
                font-weight: 800;
                color: #0f172a;
                margin-bottom: 1rem;
                letter-spacing: -0.02em;
            }

            h2 {
                font-size: 1.5rem;
                font-weight: 700;
                color: #0f172a;
                margin-top: 4rem;
                margin-bottom: 1rem;
                border-bottom: 1px solid #f1f5f9;
                padding-bottom: 1rem;
            }

            h3 {
                font-size: 1.1rem;
                font-weight: 600;
                color: #1e293b;
                margin-top: 2rem;
                margin-bottom: 0.75rem;
            }

            p {
                line-height: 1.7;
                color: #475569;
                margin-bottom: 1.5rem;
            }

            code {
                font-family: 'JetBrains Mono', monospace;
                font-size: 0.9em;
                background: #f1f5f9;
                color: #4f46e5;
                padding: 0.2rem 0.4rem;
                border-radius: 4px;
            }

            /* Tables */
            .spec-table {
                width: 100%;
                border-collapse: collapse;
                margin: 2rem 0;
                font-size: 0.9rem;
            }

            .spec-table th {
                text-align: left;
                padding: 0.75rem;
                color: #64748b;
                border-bottom: 1px solid #e2e8f0;
                font-weight: 600;
            }

            .spec-table td {
                padding: 1rem 0.75rem;
                border-bottom: 1px solid #f1f5f9;
                vertical-align: top;
            }

            .required {
                color: #ef4444;
                font-weight: 700;
                font-size: 0.7rem;
                margin-left: 4px;
            }

            /* Code Blocks in Code Panel */
            .code-block-wrapper {
                margin-bottom: 3rem;
            }

            .code-block-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 0.75rem;
            }

            .code-lang-tag {
                background: #334155;
                color: #cbd5e1;
                font-size: 0.7rem;
                font-weight: 700;
                padding: 0.2rem 0.5rem;
                border-radius: 4px;
                text-transform: uppercase;
            }

            /* Badges */
            .method-badge {
                background: #10b981;
                color: #fff;
                padding: 0.2rem 0.5rem;
                border-radius: 4px;
                font-weight: 700;
                font-size: 0.75rem;
                margin-right: 0.5rem;
            }

            /* Diagram Wrapper */
            .diagram-card {
                background: #f8fafc;
                border: 1px solid #e2e8f0;
                border-radius: 12px;
                padding: 2rem;
                margin: 2rem 0;
            }

            /* Alert styling */
            .doc-alert {
                padding: 1rem;
                border-radius: 8px;
                margin: 1.5rem 0;
                border-left: 4px solid;
            }

            .doc-alert-warning {
                background: #fff7ed;
                border-color: #f97316;
                color: #9a3412;
            }

            .doc-alert-info {
                background: #eff6ff;
                border-color: #3b82f6;
                color: #1e40af;
            }

            @media (max-width: 1200px) {
                .docs-code-panel {
                    display: none;
                }

                .docs-content {
                    max-width: 100%;
                }
            }

            @media (max-width: 768px) {
                .docs-sidebar {
                    display: none;
                }

                .docs-main {
                    margin-left: 0;
                }
            }
        </style>
</head>

<body>
    <div class="docs-container">
        <!-- Sidebar -->
        <aside class="docs-sidebar">
            <div class="mb-5 px-3">
                <a href="/" class="d-flex align-items-center gap-2 text-decoration-none">
                    <div
                        style="width:32px;height:32px;background:linear-gradient(135deg,#4f46e5,#7c3aed);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                        <i class="fi fi-rr-wallet text-white"></i>
                    </div>
                    <span style="font-weight:800;font-size:1.2rem;color:#fff;letter-spacing:-.03em;">
                        <%= settings.brand_name %>
                    </span>
                </a>
            </div>

            <div class="sidebar-search">
                <i class="fi fi-rr-search"></i>
                <input type="text" placeholder="Search documentation..." id="docsSearch">
            </div>

            <nav class="flex-grow-1">
                <div class="sidebar-heading">Getting Started</div>
                <ul class="sidebar-nav">
                    <li><a href="#intro" class="sidebar-link active"><i class="fi fi-rr-info"></i> Introduction</a></li>
                    <li><a href="#authentication" class="sidebar-link"><i class="fi fi-rr-shield-check"></i>
                            Authentication</a></li>
                    <li><a href="#idempotency" class="sidebar-link"><i class="fi fi-rr-refresh"></i> Idempotency</a>
                    </li>
                </ul>

                <div class="sidebar-heading">Core Payments</div>
                <ul class="sidebar-nav">
                    <li><a href="#create-order" class="sidebar-link"><i class="fi fi-rr-plus-small"></i> Create
                            Order</a></li>
                    <li><a href="#polling-status" class="sidebar-link"><i class="fi fi-rr-search-alt"></i> Check
                            Status</a></li>
                    <li><a href="#webhooks" class="sidebar-link"><i class="fi fi-rr-chart-connected"></i> Webhooks</a>
                    </li>
                </ul>

                <div class="sidebar-heading">Resources</div>
                <ul class="sidebar-nav">
                    <li><a href="#error-codes" class="sidebar-link"><i class="fi fi-rr-exclamation"></i> Error Codes</a>
                    </li>
                    <li><a href="#sdk-plugins" class="sidebar-link"><i class="fi fi-rr-puzzle-piece"></i> SDKs &
                            Plugins</a></li>
                    <li><a href="#support" class="sidebar-link"><i class="fi fi-rr-headset"></i> Technical Support</a>
                    </li>
                </ul>
            </nav>

            <div class="mt-auto pt-4 border-top border-light">
                <a href="/auth/dashboard" class="sidebar-link text-primary fw-bold"
                    style="background: rgba(79, 70, 229, 0.05);">
                    <i class="fi fi-rr-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="docs-main">
            <!-- Center Content -->
            <div class="docs-content">
                <section id="intro">
                    <h1>API Reference</h1>
                    <p>The Paybilupi API is organized around REST. Our API has predictable resource-oriented URLs,
                        accepts form-encoded/JSON request bodies, returns JSON-encoded responses, and uses standard HTTP
                        response codes.</p>

                    <h3>Integration Flow</h3>
                    <p>To accept a payment, you follow a simple 3-step process. First, create an order via API. Second,
                        redirect the customer to the <code>payment_url</code>. Third, handle the real-time status update
                        via webhooks.</p>
                    <div class="diagram-card">
                        <div class="mermaid">
                            sequenceDiagram
                            participant M as Your Server
                            participant P as Paybilupi
                            participant U as Customer (UPI App)

                            M->>P: 1. Create Order (POST)
                            P-->>M: return payment_url
                            M->>U: 2. Redirect User
                            U->>P: Real-time Bank Sync
                            P->>M: 3. Webhook Notif (POST)
                        </div>
                    </div>
                </section>

                <section id="authentication">
                    <h2>Authentication</h2>
                    <p>Authenticate your account by including your secret API key in the <code>user_token</code> field
                        of your POST requests. This key identifies your merchant account and permissions.</p>
                    <div class="doc-alert doc-alert-warning">
                        <strong>Security Warning:</strong> Your API Secret Key is sensitive. Never expose it in
                        client-side code, public repositories, or unsecured environments.
                    </div>
                </section>

                <section id="idempotency">
                    <h2>Idempotency</h2>
                    <p>The API supports idempotency for safely retrying requests. If you send a request with an
                        <code>order_id</code> that has already been successfully processed, the API will return the
                        existing record instead of creating a duplicate.
                    </p>
                    <p>This prevents double-billing and ensures consistent state across retries.</p>
                </section>

                <section id="create-order">
                    <h2>Create Order</h2>
                    <p>Initiate a new UPI transaction by creating an order. This endpoint returns both a
                        <code>payment_url</code> (for web browsers) and <code>upi_intent</code> (for direct mobile app
                        switching).
                    </p>

                    <div class="d-flex align-items-center mb-4">
                        <span class="method-badge">POST</span>
                        <code>https://<%= host %>/api/create-order</code>
                    </div>

                    <h3>Request Parameters</h3>
                    <table class="spec-table">
                        <thead>
                            <tr>
                                <th>Field</th>
                                <th>Type</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><code>user_token</code></td>
                                <td>string</td>
                                <td>Yes <span class="required">*</span><br><small>Your merchant Secret Key.</small></td>
                            </tr>
                            <tr>
                                <td><code>amount</code></td>
                                <td>decimal</td>
                                <td>Yes <span class="required">*</span><br><small>Transaction amount. Ex: 299.00</small>
                                </td>
                            </tr>
                            <tr>
                                <td><code>order_id</code></td>
                                <td>string</td>
                                <td>Yes <span class="required">*</span><br><small>Unique reference from your
                                        system.</small></td>
                            </tr>
                            <tr>
                                <td><code>customer_mobile</code></td>
                                <td>string</td>
                                <td>Yes <span class="required">*</span><br><small>Customer mobile for tracing.</small>
                                </td>
                            </tr>
                            <tr>
                                <td><code>redirect_url</code></td>
                                <td>string</td>
                                <td>Yes <span class="required">*</span><br><small>Return URL after payment.</small></td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="doc-alert doc-alert-info">
                        <strong>Note:</strong> The <code>order_id</code> should ideally be a random alphanumeric string
                        to prevent collisions.
                    </div>
                </section>

                <section id="polling-status">
                    <h2>Check Status</h2>
                    <p>Manually verify the status of a transaction. Use this as a fallback if you haven't received a
                        webhook within a reasonable timeframe (e.g., 30 seconds).</p>
                    <div class="d-flex align-items-center mb-4">
                        <span class="method-badge">POST</span>
                        <code>https://<%= host %>/api/check-status</code>
                    </div>

                    <h3>Request Parameters</h3>
                    <table class="spec-table">
                        <thead>
                            <tr>
                                <th>Field</th>
                                <th>Type</th>
                                <th>Required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><code>user_token</code></td>
                                <td>string</td>
                                <td>Yes <span class="required">*</span></td>
                            </tr>
                            <tr>
                                <td><code>order_id</code></td>
                                <td>string</td>
                                <td>Yes <span class="required">*</span></td>
                            </tr>
                        </tbody>
                    </table>
                </section>

                <section id="webhooks">
                    <h2>Webhooks</h2>
                    <p>Webhooks provide the most reliable way to receive payment confirmations. When a user completes a
                        payment, Paybilupi sends a <code>POST</code> notification to your configured Callback URL.</p>
                    <p><strong>Verification:</strong> To verify a webhook, you should call the Check Status API using
                        the <code>trx_id</code> or <code>order_id</code> received in the webhook payload.</p>
                </section>

                <section id="error-codes">
                    <h2>Error Codes</h2>
                    <table class="spec-table">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Detailed Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><code>INVALID_USER_TOKEN</code></td>
                                <td>The secret key provided is incorrect or the account is suspended.</td>
                            </tr>
                            <tr>
                                <td><code>ORDER_ALREADY_PAID</code></td>
                                <td>The transaction linked to this order_id is already completed.</td>
                            </tr>
                            <tr>
                                <td><code>PLAN_EXPIRED</code></td>
                                <td>The merchant premium plan has ended. Renewal is required to accept new payments.
                                </td>
                            </tr>
                            <tr>
                                <td><code>GATEWAY_ERROR</code></td>
                                <td>Temporary issue connecting to the UPI node. Retry after some time.</td>
                            </tr>
                        </tbody>
                    </table>
                </section>

                <section id="sdk-plugins">
                    <h2>SDKs & Plugins</h2>
                    <p>Integrate Paybilupi into your existing platforms with our official plugins and community SDKs.
                    </p>
                    <div class="row g-4 mt-2">
                        <div class="col-md-6">
                            <div class="premium-card p-4 border border-light shadow-sm mb-3">
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center"
                                        style="width:40px;height:40px;">
                                        <i class="fi fi-rr-shopping-cart"></i>
                                    </div>
                                    <h4 class="h6 fw-bold mb-0">WooCommerce Plugin</h4>
                                </div>
                                <p class="small text-muted mb-3">Easy integration for your WordPress store. Supports
                                    direct UPI and QR payments.</p>
                                <a href="#" class="btn btn-sm btn-alt w-100">Download V1.2.0</a>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="premium-card p-4 border border-light shadow-sm mb-3">
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center"
                                        style="width:40px;height:40px;">
                                        <i class="fi fi-rr-java"></i>
                                    </div>
                                    <h4 class="h6 fw-bold mb-0">Node.js SDK</h4>
                                </div>
                                <p class="small text-muted mb-3">Official NPM package for server-side integration.
                                    Supports async/await patterns.</p>
                                <a href="#" class="btn btn-sm btn-alt w-100">npm install paybilupi</a>
                            </div>
                        </div>
                    </div>
                </section>

                <section id="support">
                    <h2>Technical Support</h2>
                    <p>Our engineering team is here to help you with your integration 24/7. Whether you have a question
                        about our APIs or need help debugging a webhook, we've got you covered.</p>

                    <div class="premium-card p-5 bg-primary bg-gradient text-white border-0 shadow-lg mt-4">
                        <div class="row align-items-center">
                            <div class="col-lg-8">
                                <h3 class="text-white mt-0 mb-2">Need direct assistance?</h3>
                                <p class="text-white text-opacity-75 mb-4">Connect with our integration engineers
                                    directly on WhatsApp for real-time support.</p>
                                <div class="d-flex flex-wrap gap-3">
                                    <a href="https://wa.me/<%= settings.whatsapp_number %>"
                                        class="btn btn-light px-4 py-2 rounded-pill fw-bold" target="_blank">
                                        <i class="fi fi-rr-phone-call me-2"></i> Chat on WhatsApp
                                    </a>
                                    <a href="mailto:support@<%= host %>"
                                        class="btn btn-outline-light px-4 py-2 rounded-pill fw-bold">
                                        <i class="fi fi-rr-envelope me-2"></i> Email Support
                                    </a>
                                </div>
                            </div>
                            <div class="col-lg-4 d-none d-lg-block text-center">
                                <i class="fi fi-rr-headset" style="font-size: 5rem; opacity: 0.2;"></i>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <!-- Right Sidebar (Code) -->
            <div class="docs-code-panel">
                <div class="code-block-wrapper">
                    <div class="code-block-header">
                        <h4 class="small fw-bold text-white-50 mb-0">Example: Create Order</h4>
                        <div class="code-lang-tag">cURL</div>
                    </div>
                    <pre><code class="language-bash">curl -X POST https://<%= host %>/api/create-order \
  -H "Content-Type: application/json" \
  -d '{
    "user_token": "sk_test_...",
    "amount": 1.00,
    "order_id": "ORDER_1001",
    "customer_mobile": "9988776655",
    "redirect_url": "https://mysite.com/done"
  }'</code></pre>
                </div>

                <div class="code-block-wrapper">
                    <div class="code-block-header">
                        <h4 class="small fw-bold text-white-50 mb-0">Success Response</h4>
                        <div class="code-lang-tag">JSON</div>
                    </div>
                    <pre><code class="language-json">{
  "status": true,
  "message": "Order Created",
  "result": {
    "orderId": "ORDER_1001",
    "payment_url": "https://<%= host %>/pay/5x..",
    "upi_intent": "upi://pay?pa=..&am=1.00"
  }
}</code></pre>
                </div>

                <div class="code-block-wrapper">
                    <div class="code-block-header">
                        <h4 class="small fw-bold text-white-50 mb-0">Node.js implementation</h4>
                        <div class="code-lang-tag">JavaScript</div>
                    </div>
                    <pre><code class="language-javascript">const axios = require('axios');

async function handlePayment() {
  const { data } = await axios.post('/api/create-order', {
    user_token: 'YOUR_SECRET_KEY',
    amount: 100,
    order_id: 'TX_9901',
    customer_mobile: '9123456789',
    redirect_url: 'https://site.com/callback'
  });
  
  if (data.status) {
    window.location.href = data.result.payment_url;
  }
}</code></pre>
                </div>

                <div class="code-block-wrapper">
                    <div class="code-block-header">
                        <h4 class="small fw-bold text-white-50 mb-0">Webhook Listener (EJS/Express)</h4>
                        <div class="code-lang-tag">JavaScript</div>
                    </div>
                    <pre><code class="language-javascript">app.post('/webhook', (req, res) => {
  const { trx_id, amount, status } = req.body;
  
  if (status === '1') {
    // Payment Successful
    updateDatabase(trx_id, 'PAID');
  }
  
  res.sendStatus(200);
});</code></pre>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-json.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-bash.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-javascript.min.js"></script>
    <script>
        mermaid.initialize({ startOnLoad: true, theme: 'neutral' });

        // Search Logic
        const docsSearch = document.getElementById('docsSearch');
        const sidebarLinks = document.querySelectorAll('.sidebar-link');
        const sections = document.querySelectorAll('section[id]');

        docsSearch.addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            sidebarLinks.forEach(link => {
                const text = link.textContent.toLowerCase();
                const isHeading = link.parentElement.classList.contains('sidebar-heading');
                if (text.includes(term)) {
                    link.parentElement.style.display = 'block';
                } else {
                    link.parentElement.style.display = term === '' ? 'block' : 'none';
                }
            });
        });

        // Scrollspy logic
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.5
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const id = entry.target.getAttribute('id');
                    sidebarLinks.forEach(link => {
                        link.classList.remove('active');
                        if (link.getAttribute('href') === `#${id}`) {
                            link.classList.add('active');
                        }
                    });
                }
            });
        }, observerOptions);

        sections.forEach(section => observer.observe(section));

        // Smooth scroll for anchors
        sidebarLinks.forEach(link => {
            link.addEventListener('click', (e) => {
                const href = link.getAttribute('href');
                if (href.startsWith('#')) {
                    e.preventDefault();
                    const target = document.querySelector(href);
                    if (target) {
                        target.scrollIntoView({ behavior: 'smooth' });
                    }
                }
            });
        });
    </script>
</body>

</html>