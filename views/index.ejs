<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('partials/head') %>
        <title>Paybilupi – India's Zero-Fee UPI Payment Gateway</title>
        <meta name="description"
            content="Accept UPI payments with zero processing fees. Instant settlements, multi-gateway support, and a developer-first API built for modern Indian businesses.">
        <style>
            /* ──────────────────────────────────────────────────
           DESIGN TOKENS
        ────────────────────────────────────────────────── */
            :root {
                --ink: #0a0f1c;
                --ink-80: #1e2940;
                --ink-60: #4a5568;
                --ink-40: #94a3b8;
                --surface: #f8faff;
                --white: #ffffff;
                --indigo: #4f46e5;
                --indigo-d: #3730a3;
                --violet: #7c3aed;
                --cyan: #06b6d4;
                --green: #10b981;
                --amber: #f59e0b;
                --rose: #f43f5e;
                --border: #e4e9f2;
                --radius-sm: 10px;
                --radius: 16px;
                --radius-lg: 24px;
            }

            /* ──────────────────────────────────────────────────
           BASE
        ────────────────────────────────────────────────── */
            *,
            *::before,
            *::after {
                box-sizing: border-box;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                background: #fff;
                color: var(--ink);
                overflow-x: hidden;
            }

            ::selection {
                background: rgba(79, 70, 229, .15);
            }

            /* ──────────────────────────────────────────────────
           TYPOGRAPHY
        ────────────────────────────────────────────────── */
            .display-hero {
                font-size: clamp(2.5rem, 6vw, 4.5rem);
                font-weight: 900;
                line-height: 1.05;
                letter-spacing: -0.04em;
            }

            .section-eyebrow {
                display: inline-block;
                font-size: 0.72rem;
                font-weight: 700;
                letter-spacing: 0.13em;
                text-transform: uppercase;
                color: var(--indigo);
                margin-bottom: 14px;
            }

            .section-h {
                font-size: clamp(1.8rem, 3.5vw, 2.6rem);
                font-weight: 800;
                letter-spacing: -0.025em;
                color: var(--ink);
                line-height: 1.18;
            }

            /* ──────────────────────────────────────────────────
           GRADIENT TEXT
        ────────────────────────────────────────────────── */
            .g-text {
                background: linear-gradient(135deg, var(--indigo) 0%, var(--violet) 50%, #c026d3 100%);
                -webkit-background-clip: text;
                background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            /* ──────────────────────────────────────────────────
           NAVBAR
        ────────────────────────────────────────────────── */
            #lp-nav {
                position: fixed;
                top: 0;
                inset-inline: 0;
                z-index: 1050;
                padding: 20px 0;
                transition: padding .3s ease, background .3s ease, box-shadow .3s ease;
            }

            #lp-nav.scrolled {
                padding: 13px 0;
                background: rgba(255, 255, 255, .94);
                backdrop-filter: saturate(180%) blur(14px);
                -webkit-backdrop-filter: saturate(180%) blur(14px);
                box-shadow: 0 1px 0 var(--border);
            }

            .nav-link-lp {
                font-size: .875rem;
                font-weight: 500;
                color: var(--ink-60);
                text-decoration: none;
                padding: 6px 4px;
                transition: color .18s;
                position: relative;
            }

            .nav-link-lp::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: var(--indigo);
                border-radius: 2px;
                transform: scaleX(0);
                transition: transform .2s;
            }

            .nav-link-lp:hover {
                color: var(--ink);
            }

            .nav-link-lp:hover::after {
                transform: scaleX(1);
            }

            /* ──────────────────────────────────────────────────
           BUTTONS
        ────────────────────────────────────────────────── */
            .btn-cta {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: var(--indigo);
                color: #fff !important;
                border: none;
                outline: none;
                font-weight: 600;
                font-size: .9rem;
                letter-spacing: -.01em;
                padding: 13px 24px;
                border-radius: var(--radius-sm);
                text-decoration: none;
                box-shadow: 0 1px 3px rgba(79, 70, 229, .25), 0 4px 14px rgba(79, 70, 229, .25);
                transition: background .2s, transform .2s, box-shadow .2s;
                cursor: pointer;
            }

            .btn-cta:hover {
                background: var(--indigo-d);
                transform: translateY(-1px);
                box-shadow: 0 2px 6px rgba(79, 70, 229, .2), 0 8px 24px rgba(79, 70, 229, .3);
            }

            .btn-cta-lg {
                padding: 16px 36px;
                font-size: 1rem;
                border-radius: var(--radius-sm);
            }

            .btn-outline-lp {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: transparent;
                color: var(--ink) !important;
                border: 1.5px solid var(--border);
                font-weight: 600;
                font-size: .9rem;
                padding: 13px 24px;
                border-radius: var(--radius-sm);
                text-decoration: none;
                transition: border-color .2s, background .2s, color .2s;
            }

            .btn-outline-lp:hover {
                border-color: var(--indigo);
                background: rgba(79, 70, 229, .05);
                color: var(--indigo) !important;
            }

            /* ──────────────────────────────────────────────────
           HERO SECTION
        ────────────────────────────────────────────────── */
            #hero {
                min-height: 100vh;
                padding: 130px 0 80px;
                background: #fff;
                position: relative;
                overflow: hidden;
                display: flex;
                align-items: center;
            }

            /* Noise / mesh overlay */
            #hero::before {
                content: '';
                position: absolute;
                inset: 0;
                z-index: 0;
                background:
                    radial-gradient(ellipse 70% 60% at 80% 20%, rgba(99, 102, 241, .1) 0%, transparent 60%),
                    radial-gradient(ellipse 50% 50% at 10% 80%, rgba(6, 182, 212, .07) 0%, transparent 60%);
            }

            /* Subtle grid */
            #hero::after {
                content: '';
                position: absolute;
                inset: 0;
                z-index: 0;
                background-image: linear-gradient(var(--border) 1px, transparent 1px), linear-gradient(to right, var(--border) 1px, transparent 1px);
                background-size: 48px 48px;
                mask-image: radial-gradient(ellipse 80% 80% at 50% 0%, #000 50%, transparent 100%);
                opacity: .35;
            }

            /* Floating badge */
            .hero-chip {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                border: 1px solid rgba(99, 102, 241, .25);
                background: rgba(99, 102, 241, .06);
                padding: 7px 16px;
                border-radius: 100px;
                font-size: .78rem;
                font-weight: 600;
                color: var(--indigo);
                margin-bottom: 28px;
                letter-spacing: .06em;
                text-transform: uppercase;
            }

            .pulse-dot {
                width: 8px;
                height: 8px;
                background: var(--green);
                border-radius: 50%;
                box-shadow: 0 0 0 0 rgba(16, 185, 129, .5);
                animation: pulse-ring 1.6s infinite;
            }

            @keyframes pulse-ring {
                0% {
                    box-shadow: 0 0 0 0 rgba(16, 185, 129, .5);
                }

                70% {
                    box-shadow: 0 0 0 7px rgba(16, 185, 129, 0);
                }

                100% {
                    box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
                }
            }

            /* Trust strip */
            .trust-strip {
                display: flex;
                gap: 24px;
                flex-wrap: wrap;
                align-items: center;
            }

            .trust-item {
                display: flex;
                align-items: center;
                gap: 7px;
                font-size: .8rem;
                font-weight: 500;
                color: var(--ink-60);
            }

            /* ──────────────────────────────────────────────────
           HERO CARD
        ────────────────────────────────────────────────── */
            .hero-ui-card {
                background: #fff;
                border: 1px solid var(--border);
                border-radius: var(--radius-lg);
                box-shadow:
                    0 0 0 1px var(--border),
                    0 8px 32px -4px rgba(0, 0, 0, .1),
                    0 32px 80px -8px rgba(79, 70, 229, .12);
                overflow: hidden;
            }

            .hero-ui-card .card-header-bar {
                background: var(--surface);
                border-bottom: 1px solid var(--border);
                padding: 14px 20px;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .win-btn {
                width: 12px;
                height: 12px;
                border-radius: 50%;
            }

            .win-r {
                background: #ff5f57;
            }

            .win-y {
                background: #fec62e;
            }

            .win-g {
                background: #28c840;
            }

            .hero-ui-card .card-body-pad {
                padding: 24px;
            }

            /* Metric row inside card */
            .metric-row {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 12px;
                padding: 16px;
                margin-bottom: 12px;
            }

            .metric-amount {
                font-size: 1.6rem;
                font-weight: 800;
                letter-spacing: -.03em;
                color: var(--ink);
            }

            /* Mini sparkline */
            .sparkline {
                display: flex;
                align-items: flex-end;
                gap: 3px;
                height: 36px;
            }

            .sparkline span {
                flex: 1;
                border-radius: 3px 3px 0 0;
                background: linear-gradient(to top, var(--indigo), var(--violet));
                opacity: .7;
                transition: opacity .2s;
            }

            .sparkline span:hover {
                opacity: 1;
            }

            /* Gateway row */
            .gw-item {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 11px 14px;
                border: 1px solid var(--border);
                border-radius: 10px;
                background: #fff;
                margin-bottom: 8px;
            }

            .gw-status {
                font-size: .7rem;
                font-weight: 600;
                color: var(--green);
                background: rgba(16, 185, 129, .08);
                border: 1px solid rgba(16, 185, 129, .2);
                padding: 3px 10px;
                border-radius: 100px;
            }

            /* ──────────────────────────────────────────────────
           STATS TICKER
        ────────────────────────────────────────────────── */
            .stats-ticker {
                background: var(--ink);
                padding: 40px 0;
            }

            .stats-ticker .s-val {
                font-size: 2.2rem;
                font-weight: 900;
                letter-spacing: -.03em;
                color: #fff;
                line-height: 1;
            }

            .stats-ticker .s-lbl {
                font-size: .72rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: .1em;
                color: rgba(255, 255, 255, .45);
                margin-top: 5px;
            }

            .stats-ticker .s-divider {
                width: 1px;
                height: 40px;
                background: rgba(255, 255, 255, .1);
            }

            /* ──────────────────────────────────────────────────
           FEATURES GRID
        ────────────────────────────────────────────────── */
            #features {
                background: var(--surface);
            }

            .feat-card {
                background: #fff;
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: 30px;
                height: 100%;
                transition: border-color .25s, box-shadow .25s, transform .25s;
                position: relative;
                overflow: hidden;
            }

            .feat-card::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, rgba(79, 70, 229, .03) 0%, transparent 60%);
                opacity: 0;
                transition: opacity .25s;
            }

            .feat-card:hover {
                border-color: rgba(79, 70, 229, .3);
                box-shadow: 0 12px 36px -8px rgba(79, 70, 229, .12);
                transform: translateY(-5px);
            }

            .feat-card:hover::before {
                opacity: 1;
            }

            .feat-icon-wrap {
                width: 50px;
                height: 50px;
                border-radius: 14px;
                display: flex;
                align-items: center;
                justify-content: center;
                margin-bottom: 20px;
                font-size: 1.25rem;
            }

            .feat-card h5 {
                font-size: 1rem;
                font-weight: 700;
                margin-bottom: 10px;
                color: var(--ink);
            }

            .feat-card p {
                font-size: .85rem;
                color: var(--ink-60);
                line-height: 1.7;
                margin: 0;
            }

            /* ──────────────────────────────────────────────────
           HOW IT WORKS
        ────────────────────────────────────────────────── */
            #how-it-works {
                background: #fff;
            }

            .step-pill {
                width: 46px;
                height: 46px;
                border-radius: 50%;
                background: linear-gradient(135deg, var(--indigo), var(--violet));
                color: #fff;
                font-weight: 700;
                font-size: 1.05rem;
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 4px 14px rgba(79, 70, 229, .35);
                flex-shrink: 0;
            }

            .step-pill.done {
                background: var(--ink);
            }

            .step-connector {
                width: 2px;
                min-height: 32px;
                background: linear-gradient(to bottom, rgba(79, 70, 229, .5), rgba(79, 70, 229, .05));
                margin: 6px auto;
            }

            /* Code window */
            .code-win {
                background: var(--ink);
                border-radius: var(--radius);
                overflow: hidden;
                box-shadow: 0 24px 64px -16px rgba(0, 0, 0, .25);
                border: 1px solid rgba(255, 255, 255, .06);
            }

            .code-win-bar {
                background: #1a2236;
                padding: 12px 20px;
                display: flex;
                align-items: center;
                gap: 8px;
                border-bottom: 1px solid rgba(255, 255, 255, .05);
            }

            .code-win pre {
                margin: 0;
                padding: 24px;
                font-size: .8rem;
                line-height: 1.8;
                white-space: pre-wrap;
                color: #cdd6f4;
            }

            /* ──────────────────────────────────────────────────
           TESTIMONIALS
        ────────────────────────────────────────────────── */
            #testimonials {
                background: var(--surface);
            }

            .testi-card {
                background: #fff;
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: 28px;
                height: 100%;
                transition: box-shadow .2s, transform .2s;
            }

            .testi-card:hover {
                box-shadow: 0 12px 32px -8px rgba(0, 0, 0, .08);
                transform: translateY(-3px);
            }

            .testi-stars {
                color: var(--amber);
                font-size: .85rem;
                letter-spacing: 2px;
            }

            .testi-text {
                font-size: .875rem;
                color: var(--ink-60);
                line-height: 1.75;
            }

            .testi-avatar {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                font-weight: 700;
                font-size: .9rem;
                color: #fff;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            /* ──────────────────────────────────────────────────
           CTA CALLOUT
        ────────────────────────────────────────────────── */
            .cta-callout {
                background: linear-gradient(135deg, var(--indigo) 0%, var(--violet) 100%);
                border-radius: var(--radius-lg);
                padding: 72px 48px;
                position: relative;
                overflow: hidden;
            }

            .cta-callout::before {
                content: '';
                position: absolute;
                top: -80px;
                right: -80px;
                width: 320px;
                height: 320px;
                background: rgba(255, 255, 255, .07);
                border-radius: 50%;
            }

            .cta-callout::after {
                content: '';
                position: absolute;
                bottom: -60px;
                left: 120px;
                width: 200px;
                height: 200px;
                background: rgba(255, 255, 255, .05);
                border-radius: 50%;
            }

            /* ──────────────────────────────────────────────────
           FOOTER
        ────────────────────────────────────────────────── */
            #lp-footer {
                background: var(--ink);
                padding-top: 64px;
                padding-bottom: 40px;
            }

            #lp-footer .f-divider {
                border-top: 1px solid rgba(255, 255, 255, .07);
                margin: 36px 0 28px;
            }

            #lp-footer h6 {
                color: #fff;
                font-size: .72rem;
                text-transform: uppercase;
                letter-spacing: .1em;
                font-weight: 700;
                margin-bottom: 18px;
            }

            #lp-footer a {
                color: rgba(255, 255, 255, .5);
                font-size: .85rem;
                text-decoration: none;
                transition: color .18s;
                line-height: 2.2;
                display: block;
            }

            #lp-footer a:hover {
                color: #fff;
            }

            /* ──────────────────────────────────────────────────
           AOS-like fade helpers
        ────────────────────────────────────────────────── */
            [data-fade] {
                opacity: 0;
                transform: translateY(24px);
                transition: opacity .6s ease, transform .6s ease;
            }

            [data-fade].visible {
                opacity: 1;
                transform: none;
            }

            [data-fade="left"] {
                transform: translateX(-28px);
            }

            [data-fade="left"].visible {
                transform: none;
            }

            [data-fade="right"] {
                transform: translateX(28px);
            }

            [data-fade="right"].visible {
                transform: none;
            }

            /* Responsive tweaks */
            @media (max-width: 768px) {
                .cta-callout {
                    padding: 48px 28px;
                }

                .display-hero {
                    letter-spacing: -.025em;
                }
            }
        </style>
</head>

<body class="font-outfit">

    <!-- ═══════════════════════════════════
     NAVBAR
═══════════════════════════════════ -->
    <nav id="lp-nav">
        <div class="container">
            <div class="d-flex align-items-center justify-content-between">

                <!-- Logo -->
                <a href="/" class="d-flex align-items-center gap-2 text-decoration-none">
                    <div
                        style="width:36px;height:36px;background:linear-gradient(135deg,var(--indigo),var(--violet));border-radius:10px;display:flex;align-items:center;justify-content:center;">
                        <i class="fi fi-rr-wallet text-white fs-6 mt-1"></i>
