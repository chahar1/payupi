                                            <span style="height:<%=h%>%;"></span>
                                            <% }); %>
                                    </div>
                                </div>
                            </div>

                            <!-- Gateway rows -->
                            <div
                                style="margin-bottom:8px;font-size:.72rem;font-weight:700;color:var(--ink-40);text-transform:uppercase;letter-spacing:.08em;">
                                Active Gateways</div>
                            <div class="gw-item">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="https://cdn.iconscout.com/icon/free/png-256/free-phonepe-logo-icon-download-in-svg-png-gif-file-formats--technology-social-media-company-brand-vol-5-pack-logos-icons-2945035.png?f=webp"
                                        width="26" alt="PhonePe">
                                    <div>
                                        <div style="font-size:.85rem;font-weight:700;color:var(--ink);">PhonePe</div>
                                        <div style="font-size:.72rem;color:var(--ink-40);">Primary · ₹32,400 today</div>
