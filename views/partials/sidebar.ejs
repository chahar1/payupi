<% const navLinkClass="nav-link d-flex align-items-center px-4 py-3 rounded-4 transition-all mb-2" ; const
    activeClass="active" ; %>
    <div class="col-auto sidebar d-none d-md-block p-0 m-0"
        style="width: 280px; min-height: 100vh; position: sticky; top: 0; align-self: flex-start; z-index: 1000; flex-shrink: 0; border-right: 1px solid rgba(255,255,255,0.05);">
        <!-- Logo Section -->
        <div class="px-4 py-5 mb-2">
            <a href="/auth/dashboard" class="d-flex align-items-center gap-3 text-decoration-none">
                <div class="d-flex align-items-center justify-content-center bg-primary rounded-3 shadow-sm"
                    style="width: 40px; height: 40px;">
                    <i class="fi fi-sr-bolt text-white fs-4"></i>
                </div>
                <h4 class="mb-0 fw-bold text-main tracking-tight">
                    <%= settings.brand_name %><span class="text-primary">.</span>
                </h4>
            </a>
        </div>

        <div class="px-3">
            <!-- Main Features -->
            <div class="mb-4">
                <p class="extra-small fw-bold text-dim uppercase tracking-widest px-3 mb-3">Core Features</p>
                <ul class="list-unstyled">
                    <li>
                        <a href="/auth/dashboard"
                            class="<%= navLinkClass %> <%= (currentPage == 'dashboard') ? activeClass : 'text-muted hover-bg-alt' %>">
                            <i class="fi fi-rr-apps me-3"></i> <span>Dashboard</span>
                        </a>
                    </li>
                    <li><a href="/auth/connect_merchant"
                            class="<%= navLinkClass %> <%= (currentPage == 'connect_merchant') ? activeClass : 'text-muted hover-bg-alt' %>"><i
                                class="fi fi-rr-settings-sliders me-3"></i> <span>Connect bank</span></a></li>
                </ul>
            </div>

            <!-- Admin Section -->
            <% if (user && user.role=="Admin" ) { %>
                <div class="mb-4">
                    <p class="extra-small fw-bold text-dim uppercase tracking-widest px-3 mb-3">Admin</p>
                    <ul class="list-unstyled">
                        <li><a href="/auth/merchant_list"
                                class="<%= navLinkClass %> <%= (currentPage == 'merchant_list') ? activeClass : 'text-muted hover-bg-alt' %>"><i
                                    class="fi fi-rr-users me-3"></i> <span>Users</span></a></li>
                        <li><a href="/auth/manage_subscription"
                                class="<%= navLinkClass %> <%= (currentPage == 'manage_subscription') ? activeClass : 'text-muted hover-bg-alt' %>"><i
                                    class="fi fi-rr-crown me-3"></i> <span>Subscriptions</span></a></li>
                        <li><a href="/auth/sitesetting"
                                class="<%= navLinkClass %> <%= (currentPage == 'sitesetting') ? activeClass : 'text-muted hover-bg-alt' %>"><i
                                    class="fi fi-rr-settings me-3"></i> <span>Settings</span></a></li>
                        <li><a href="/auth/add_api"
                                class="<%= navLinkClass %> <%= (currentPage == 'add_api') ? activeClass : 'text-muted hover-bg-alt' %>"><i
                                    class="fi fi-rr-envelope me-3"></i> <span>Email</span></a></li>
                    </ul>
                </div>
                <% } %>

                    <!-- Payments Section -->
                    <div class="mb-4">
                        <p class="extra-small fw-bold text-dim uppercase tracking-widest px-3 mb-3">Payments</p>
                        <ul class="list-unstyled">
                            <li><a href="/auth/transactions"
                                    class="<%= navLinkClass %> <%= (currentPage == 'transactions') ? activeClass : 'text-muted hover-bg-alt' %>"><i
                                        class="fi fi-rr-chart-line-up me-3"></i> <span>Transactions</span></a></li>
                            <li><a href="/auth/payment_link"
                                    class="<%= navLinkClass %> <%= (currentPage == 'payment_link') ? activeClass : 'text-muted hover-bg-alt' %>"><i
                                        class="fi fi-rr-link me-3"></i> <span>Payment Links</span></a></li>
                        </ul>
                    </div>

                    <!-- Developer Suite -->
                    <div class="mb-4">
                        <p class="extra-small fw-bold text-dim uppercase tracking-widest px-3 mb-3">Developer</p>
                        <ul class="list-unstyled">
                            <li><a href="/auth/apidetails"
                                    class="<%= navLinkClass %> <%= (currentPage == 'apidetails') ? activeClass : 'text-muted hover-bg-alt' %>"><i
                                        class="fi fi-rr-key me-3"></i> <span>API Details</span></a></li>
                            <li><a href="/auth/docs"
                                    class="<%= navLinkClass %> <%= (currentPage == 'docs') ? activeClass : 'text-muted hover-bg-alt' %>"><i
                                        class="fi fi-rr-document me-3"></i> <span>Documentation</span></a></li>
                            <li><a href="/auth/sample_code"
                                    class="<%= navLinkClass %> <%= (currentPage == 'sample_code') ? activeClass : 'text-muted hover-bg-alt' %>"><i
                                        class="fi fi-rr-database me-3"></i> <span>Sample Code</span></a></li>
                        </ul>
                    </div>

                    <!-- Account Section -->
                    <div class="mb-4">
                        <p class="extra-small fw-bold text-dim uppercase tracking-widest px-3 mb-3">Account</p>
                        <ul class="list-unstyled">
                            <li><a href="/auth/profile"
                                    class="<%= navLinkClass %> <%= (currentPage == 'profile') ? activeClass : 'text-muted hover-bg-alt' %>"><i
                                        class="fi fi-rr-user me-3"></i> <span>Profile</span></a></li>
                            <li><a href="/auth/subscription"
                                    class="<%= navLinkClass %> <%= (currentPage == 'subscription') ? activeClass : 'text-muted hover-bg-alt' %>"><i
                                        class="fi fi-rr-crown me-3"></i> <span>Membership</span></a></li>
                        </ul>
                    </div>

                    <!-- Logout -->
                    <div class="mt-5 pt-4 border-top">
                        <a href="/auth/logout"
                            class="d-flex align-items-center px-3 py-2 text-danger hover-bg-danger-light rounded-3 transition-all text-decoration-none fw-semibold mb-4">
                            <i class="fi fi-rr-exit me-3"></i> <span>Log out</span>
                        </a>
                    </div>
        </div>
    </div>