<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
        <title>Secure Payment - <%= payment.users.name %>
        </title>
        <style>
            body {
                background-color: #f8fafc;
                background-image:
                    radial-gradient(at 0% 0%, rgba(79, 70, 229, 0.08) 0, transparent 50%),
                    radial-gradient(at 100% 0%, rgba(14, 165, 233, 0.08) 0, transparent 50%),
                    radial-gradient(at 50% 100%, rgba(16, 185, 129, 0.08) 0, transparent 50%);
                background-attachment: fixed;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
            }

            .payment-card {
                width: 100%;
                max-width: 420px;
                background: rgba(255, 255, 255, 0.85);
                backdrop-filter: blur(16px);
                -webkit-backdrop-filter: blur(16px);
                border: 1px solid rgba(255, 255, 255, 0.5);
                border-radius: 24px;
                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
                overflow: hidden;
                animation: slideUpFade 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            }

            @keyframes slideUpFade {
                from {
                    opacity: 0;
                    transform: translateY(30px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .payment-header {
                background: linear-gradient(135deg, var(--primary) 0%, #3b82f6 100%);
                padding: 30px 20px;
                text-align: center;
                color: white;
                position: relative;
            }

            .payment-header::after {
                content: '';
                position: absolute;
                bottom: -20px;
                left: 0;
                right: 0;
                height: 40px;
                background: rgba(255, 255, 255, 0.85);
                border-radius: 50% 50% 0 0;
                z-index: 0;
            }

            .merchant-avatar {
                width: 64px;
                height: 64px;
                background: white;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 24px;
                font-weight: bold;
                color: var(--primary);
                margin: 0 auto 12px auto;
                box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
                position: relative;
                z-index: 1;
            }

            .screen {
                display: none;
                animation: fadeIn 0.4s ease;
            }

            .screen.active {
                display: block;
            }

            @keyframes fadeIn {
                from {
                    opacity: 0;
                }

                to {
                    opacity: 1;
                }
            }

            .payment-option {
                background: white;
                border: 1px solid var(--border-color);
                border-radius: 16px;
                padding: 16px;
                display: flex;
                align-items: center;
                gap: 16px;
                cursor: pointer;
                transition: all 0.2s ease;
                margin-bottom: 12px;
            }

            .payment-option:hover {
                border-color: var(--primary);
                box-shadow: 0 4px 12px rgba(79, 70, 229, 0.1);
                transform: translateY(-2px);
            }

            .payment-option-icon {
                width: 48px;
                height: 48px;
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
            }

            .qr-box {
                background: white;
                padding: 20px;
                border-radius: 20px;
                border: 1px solid var(--border-color);
                display: inline-block;
                box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
                margin-bottom: 16px;
            }

            .qr-img {
                width: 200px;
                height: 200px;
            }

            .pulse-dot {
                width: 10px;
                height: 10px;
                background-color: var(--primary);
                border-radius: 50%;
                animation: pulse 1.5s infinite;
            }

            @keyframes pulse {
                0% {
                    box-shadow: 0 0 0 0 rgba(79, 70, 229, 0.4);
                }

                70% {
                    box-shadow: 0 0 0 10px rgba(79, 70, 229, 0);
                }

                100% {
                    box-shadow: 0 0 0 0 rgba(79, 70, 229, 0);
                }
            }
        </style>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>
    <div class="payment-card position-relative pb-4">
        <div class="payment-header">
            <div class="merchant-avatar">
                <%= payment.users.name.charAt(0) %>
            </div>
            <h5 class="fw-bold mb-1 position-relative z-1">
                <%= payment.users.name %>
            </h5>
            <p class="small text-white text-opacity-75 mb-0 position-relative z-1">Secure Payment Gateway</p>
        </div>

        <div class="px-4 position-relative z-1" style="margin-top: -10px;">
            <div class="text-center mb-4">
                <p class="extra-small fw-bold text-dim uppercase tracking-widest mb-1">Amount to Pay</p>
                <h2 class="fw-bold text-main mb-1">₹<%= parseFloat(payment.amount).toLocaleString('en-IN',
                        {minimumFractionDigits: 2}) %>
                </h2>
                <div class="badge bg-alt text-muted small fw-normal border">Order: #<%= payment.trx_id %>
                </div>
            </div>

            <!-- Selection Screen -->
            <div id="selection-screen" class="screen active">
                <div class="payment-option" onclick="showScreen('qr-screen')">
                    <div class="payment-option-icon bg-primary bg-opacity-10 text-primary">
                        <i class="fi fi-rr-expand"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold text-main mb-1">Scan QR Code</h6>
                        <p class="extra-small text-muted mb-0">Pay using any UPI app</p>
                    </div>
                    <i class="fi fi-rr-angle-right ms-auto text-dim"></i>
                </div>

                <div class="payment-option" onclick="showScreen('app-screen')">
                    <div class="payment-option-icon bg-success bg-opacity-10 text-success">
                        <i class="fi fi-rr-mobile-button"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold text-main mb-1">Open UPI App</h6>
                        <p class="extra-small text-muted mb-0">Pay directly from phone</p>
                    </div>
                    <i class="fi fi-rr-angle-right ms-auto text-dim"></i>
                </div>
            </div>

            <!-- QR Screen -->
            <div id="qr-screen" class="screen text-center">
                <div class="qr-box">
                    <% const
                        common_params=`pa=${upiId}&am=${payment.amount}&pn=${encodeURIComponent(payment.users.name)}&tn=${encodeURIComponent(payment.trx_id)}&tr=${payment.trx_id}&mc=4722&cu=INR&mode=02&purpose=00`;
                        const upi_url=`upi://pay?${common_params}`; const
                        paytm_url=`paytmmp://cash_wallet?${common_params}&&sign=AAuN7izDWN5cb8A5scnUiNME+LkZqI2DWgkXlN1McoP6WZABa/KkFTiLvuPRP6/nWK8BPg/rPhb+u4QMrUEX10UsANTDbJaALcSM9b8Wk218X+55T/zOzb7xoiB+BcX8yYuYayELImXJHIgL/c7nkAnHrwUCmbM97nRbCVVRvU0ku3Tr&featuretype=money_transfer`;
                        const phonepe_url=`phonepe://pay?${common_params}`; const
                        qr_url=`https://api.qrserver.com/v1/create-qr-code/?data=${encodeURIComponent(upi_url)}&size=250x250`;
                        %>
                        <img src="<%= qr_url %>" alt="QR Code" class="qr-img">
                </div>
                <p class="small text-muted mb-4">Scan with Google Pay, PhonePe, Paytm, etc.</p>
                <button class="btn btn-alt w-100 rounded-3 py-2 fw-bold" onclick="showScreen('selection-screen')">Choose
                    Another Method</button>
            </div>

            <!-- App Screen -->
            <div id="app-screen" class="screen text-center">
                <p class="small text-muted mb-4">Select your preferred UPI app to pay directly.</p>

                <% const phonepe_ios_url=`phonepe://upi/pay?${common_params}`; %>

                    <div class="d-flex justify-content-center gap-3 mb-4">
                        <a href="<%= upi_url %>" class="btn btn-light border p-3 rounded-4 transition-all hover-bg-alt">
                            <img src="https://logodownload.org/wp-content/uploads/2020/06/google-pay-logo-0.png"
                                width="40" height="40" style="object-fit: contain;">
                        </a>
                        <a href="javascript:void(0)" onclick="openPhonePe()"
                            class="btn btn-light border p-3 rounded-4 transition-all hover-bg-alt">
                            <img src="https://download.logo.wine/logo/PhonePe/PhonePe-Logo.wine.png" width="40"
                                height="40" style="object-fit: contain;">
                        </a>
                        <a href="<%= paytm_url %>"
                            class="btn btn-light border p-3 rounded-4 transition-all hover-bg-alt">
                            <img src="https://download.logo.wine/logo/Paytm/Paytm-Logo.wine.png" width="40" height="40"
                                style="object-fit: contain;">
                        </a>
                    </div>

                    <button class="btn btn-alt w-100 rounded-3 py-2 fw-bold"
                        onclick="showScreen('selection-screen')">Back</button>
            </div>

            <script>
                function openPhonePe() {
                    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
                    const phonepe_android = "<%= phonepe_url %>";
                    const phonepe_ios = "<%= phonepe_ios_url %>";

                    if (isIOS) {
                        window.location.href = phonepe_ios;
                    } else {
                        window.location.href = phonepe_android;
                    }
                }
            </script>

            <!-- Status Indicator -->
            <div class="d-flex align-items-center justify-content-center gap-2 mt-4 pt-4 border-top">
                <div class="pulse-dot"></div>
                <span class="small fw-semibold text-primary">Securely Waiting for Payment...</span>
            </div>

            <div class="text-center mt-3">
                <i class="fi fi-rr-shield-check text-success opacity-50 me-1"></i> <span
                    class="extra-small text-muted">100% Secure & Encrypted</span>
            </div>
        </div>
    </div>

    <script>
        function showScreen(id) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }

        const trxId = '<%= payment.trx_id %>';
        function checkStatus() {
            fetch('/verify', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ trxId })
            })
                .then(r => r.text())
                .then(status => {
                    if (status === 'SUCCESS') {
                        Swal.fire({
                            title: 'Payment Successful!',
                            text: 'Redirecting you back...',
                            icon: 'success',
                            showConfirmButton: false,
                            timer: 2000
                        }).then(() => {
                            window.location.href = '<%= payment.redirect_url %>';
                        });
                    }
                })
                .catch(e => console.error("Polling error", e));
        }
        setInterval(checkStatus, 3000);
    </script>
</body>

</html>