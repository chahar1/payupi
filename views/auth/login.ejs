<!DOCTYPE html>
<html lang="en">

<head>
    <title>Login | Paybilupi Business</title>
    <%- include('../partials/head') %>
        <style>
            /* CSS from auth/index.php pasted here */
            body {
                background: #ffffff;
                color: #0f172a;
                font-family: 'Inter', 'Outfit', sans-serif;
            }

            .bg-mesh {
                position: fixed;
                inset: 0;
                z-index: 0;
                background-color: #ffffff;
                background-image: radial-gradient(at 0% 0%, hsla(217, 100%, 95%, 1) 0, transparent 50%), radial-gradient(at 100% 0%, hsla(210, 100%, 96%, 1) 0, transparent 50%), radial-gradient(at 100% 100%, hsla(217, 100%, 95%, 1) 0, transparent 50%), radial-gradient(at 0% 100%, hsla(210, 100%, 96%, 1) 0, transparent 50%);
            }

            .bg-grid {
                position: fixed;
                inset: 0;
                z-index: 1;
                pointer-events: none;
                background-image: linear-gradient(rgba(37, 99, 235, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(37, 99, 235, 0.03) 1px, transparent 1px);
                background-size: 60px 60px;
            }

            .login-container {
                display: flex;
                min-height: 100vh;
                position: relative;
                z-index: 2;
            }

            .branding-section {
                flex: 1;
                display: flex;
                flex-direction: column;
                justify-content: center;
                padding: 80px;
                background: rgba(255, 255, 255, 0.4);
                backdrop-filter: blur(10px);
                border-right: 1px solid #eef2f6;
            }

            @media (max-width: 992px) {
                .branding-section {
                    display: none;
                }
            }

            .brand-logo img {
                height: 48px;
                margin-bottom: 48px;
            }

            .headline {
                font-size: 3.5rem;
                font-weight: 800;
                line-height: 1.1;
                color: #0f172a;
                margin-bottom: 24px;
                letter-spacing: -0.03em;
            }

            .headline span {
                color: #2563eb;
            }

            .subtext {
                font-size: 1.125rem;
                color: #64748b;
                line-height: 1.6;
                max-width: 480px;
                margin-bottom: 48px;
            }

            .form-section {
                flex: 1;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 40px;
            }

            .login-card {
                width: 100%;
                max-width: 440px;
                background: #ffffff;
                padding: 48px;
                border-radius: 24px;
                box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
                border: 1px solid #eef2f6;
            }

            .card-header h2 {
                font-size: 1.75rem;
                font-weight: 700;
                color: #0f172a;
                margin-bottom: 8px;
            }

            .card-header p {
                color: #64748b;
                font-size: 0.9375rem;
                margin-bottom: 32px;
            }

            .form-group {
                margin-bottom: 20px;
            }

            .form-label {
                display: block;
                font-size: 0.8125rem;
                font-weight: 600;
                color: #475569;
                margin-bottom: 8px;
                text-transform: uppercase;
                letter-spacing: 0.025em;
            }

            .input-container {
                position: relative;
            }

            .input-container i {
                position: absolute;
                left: 16px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                font-size: 1.1rem;
            }

            .form-input {
                width: 100%;
                padding: 14px 16px 14px 48px;
                background: #f8fafc;
                border: 1px solid #e2e8f0;
                border-radius: 12px;
                font-size: 1rem;
                color: #0f172a;
                transition: all 0.2s;
                outline: none;
            }

            .form-input:focus {
                background: #ffffff;
                border-color: #2563eb;
                box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
            }

            .btn-primary-premium {
                width: 100%;
                padding: 14px;
                background: #2563eb;
                color: #ffffff;
                border: none;
                border-radius: 12px;
                font-size: 1rem;
                font-weight: 600;
                cursor: pointer;
                transition: all 0.2s;
                box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.2);
            }

            .btn-primary-premium:hover {
                background: #1d4ed8;
                transform: translateY(-1px);
                box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.3);
            }

            .footer-links {
                margin-top: 32px;
                text-align: center;
                font-size: 0.875rem;
                color: #64748b;
            }

            .footer-links a {
                color: #2563eb;
                text-decoration: none;
                font-weight: 600;
            }

            .feature-pill {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                padding: 8px 16px;
                background: #f1f5f9;
                border-radius: 100px;
                font-size: 0.875rem;
                font-weight: 600;
                color: #475569;
                margin-bottom: 24px;
            }

            .feature-pill i {
                color: #2563eb;
            }
        </style>
</head>

<body>
    <div class="bg-mesh"></div>
    <div class="container d-flex flex-column justify-content-center min-vh-100 position-relative z-1 py-5">
        <div class="row justify-content-center w-100 m-0">
            <div class="col-12 col-md-10 col-lg-8 col-xl-6">
                <!-- Branding Header -->
                <div class="text-center mb-5 fade-in">
                    <div class="d-inline-flex align-items-center justify-content-center p-3 bg-white rounded-circle shadow-sm mb-4"
                        style="width: 80px; height: 80px;">
                        <i class="fi fi-rr-wallet fs-1 text-primary"></i>
                    </div>
                    <h2 class="fw-bold tracking-tight text-main mb-2">Welcome Back to Paybilupi</h2>
                    <p class="text-muted small">Sign in securely to manage your payments and settlements.</p>
                </div>

                <!-- Login Card -->
                <div class="premium-card p-4 p-md-5 mb-4 slide-up">
                    <form method="POST" action="/auth/login" id="loginForm">
                        <div class="mb-4">
                            <label class="form-label extra-small fw-bold text-dim uppercase tracking-widest">Email or
                                Mobile</label>
                            <div
                                class="input-group input-group-lg border border-light rounded-3 overflow-hidden shadow-sm">
                                <span class="input-group-text bg-white border-0 text-muted ps-4"><i
                                        class="fi fi-rr-envelope"></i></span>
                                <input type="text" name="username" class="form-control border-0 ps-2 fs-6 tracking-wide"
                                    placeholder="Enter your registered mobile or email" required>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label
                                    class="form-label extra-small fw-bold text-dim uppercase tracking-widest mb-0">Password</label>
                                <a href="/auth/forgot-password"
                                    class="text-primary small text-decoration-none fw-bold">Forgot password?</a>
                            </div>
                            <div
                                class="input-group input-group-lg border border-light rounded-3 overflow-hidden shadow-sm">
                                <span class="input-group-text bg-white border-0 text-muted ps-4"><i
                                        class="fi fi-rr-lock"></i></span>
                                <input type="password" name="password"
                                    class="form-control border-0 ps-2 fs-6 tracking-wide" placeholder="••••••••"
                                    required>
                            </div>
                        </div>

                        <% if (error) { %>
                            <div
                                class="alert alert-danger py-2 small rounded-3 d-flex align-items-center gap-2 mb-4 text-danger bg-danger bg-opacity-10 border-0">
                                <i class="fi fi-rr-info"></i>
                                <%= error %>
                            </div>
                            <% } %>

                                <button type="submit"
                                    class="btn btn-premium w-100 py-3 rounded-3 fw-bold fs-6 d-flex justify-content-center align-items-center gap-2 mt-2">
                                    Sign In Securely <i class="fi fi-rr-arrow-right"></i>
                                </button>
                    </form>
                </div>

                <!-- Footer Links -->
                <div class="text-center fade-in delay-2">
                    <p class="small text-muted mb-0">Don't have a merchant account yet? <a href="/auth/register"
                            class="text-primary fw-bold text-decoration-none">Create Account</a></p>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
</body>

</html>