<!DOCTYPE html>
<html>

<head>
    <%- include('../partials/head') %>
        <title>Payment Links | Paybilupi</title>
</head>

<body class="bg-mesh">
    <div class="container-fluid p-0">
        <div class="row g-0">
            <%- include('../partials/sidebar') %>
                <div class="col">
                    <%- include('../partials/header') %>

                        <div class="px-4 py-5" style="min-height: calc(100vh - 70px);">
                            <div class="mb-5" data-aos="fade-down">
                                <h2 class="fw-bold mb-1 tracking-tight text-main">Payment Links</h2>
                                <p class="text-muted small mb-0">Create and share payment links to get paid faster.</p>
                            </div>

                            <% if (paymentlink) { %>
                                <div class="alert alert-success bg-success bg-opacity-10 border-success border-opacity-25 d-flex flex-column flex-sm-row align-items-sm-center justify-content-between p-4 rounded-4 mb-5 shadow-sm"
                                    data-aos="fade-down">
                                    <div class="d-flex align-items-center gap-3 mb-3 mb-sm-0">
                                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                            style="width: 48px; height: 48px; font-size: 1.25rem;">
                                            <i class="fi fi-rr-check"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold text-success mb-1">Payment Link Created!</h6>
                                            <p class="small text-success text-opacity-75 mb-0">Share this link: <code
                                                    class="bg-white px-2 py-1 rounded text-primary ms-1"><%= paymentlink %></code>
                                            </p>
                                        </div>
                                    </div>
                                    <button class="btn btn-success px-4 rounded-3 shadow-sm transition-all text-white"
                                        onclick="navigator.clipboard.writeText('<%= paymentlink %>'); this.innerHTML='<i class=\'fi fi-rr-check me-2\'></i>Copied!'; this.classList.remove('btn-success'); this.classList.add('bg-success', 'bg-opacity-75', 'btn', 'text-white'); setTimeout(() => { this.innerHTML='Copy Link'; this.classList.remove('bg-success', 'bg-opacity-75'); this.classList.add('btn-success'); }, 2000);">Copy
                                        Link</button>
                                </div>
                                <% } %>

                                    <div class="row g-5">
                                        <div class="col-lg-5" data-aos="fade-right" data-aos-delay="100">
                                            <div
                                                class="premium-card p-4 p-lg-5 h-100 position-relative overflow-hidden">
                                                <!-- Decorative Background -->
                                                <div
                                                    class="position-absolute top-0 end-0 p-4 opacity-5 pointer-events-none">
                                                    <i class="fi fi-rr-link-alt" style="font-size: 8rem;"></i>
                                                </div>

                                                <div class="position-relative z-1">
                                                    <h5 class="fw-bold text-main mb-4">Create New Link</h5>
                                                    <form method="POST" action="/auth/payment_link">
                                                        <div class="mb-4">
                                                            <label
                                                                class="form-label extra-small fw-bold text-dim uppercase tracking-widest">Customer
                                                                Name</label>
                                                            <div
                                                                class="input-group input-group-lg border border-light rounded-3 overflow-hidden shadow-sm">
                                                                <span
                                                                    class="input-group-text bg-white border-0 text-muted ps-4"><i
                                                                        class="fi fi-rr-user"></i></span>
                                                                <input type="text" name="name"
                                                                    class="form-control border-0 ps-2 fs-6 tracking-wide"
                                                                    placeholder="e.g. Rahul Kumar">
                                                            </div>
                                                        </div>
                                                        <div class="mb-4">
                                                            <label
                                                                class="form-label extra-small fw-bold text-dim uppercase tracking-widest">Amount
                                                                <span class="text-danger">*</span></label>
                                                            <div
                                                                class="input-group input-group-lg border border-primary border-opacity-25 rounded-3 overflow-hidden shadow-sm">
                                                                <span
                                                                    class="input-group-text bg-primary bg-opacity-10 border-0 text-primary ps-4 fw-bold">₹</span>
                                                                <input type="number" name="amount"
                                                                    class="form-control border-0 ps-2 fs-5 fw-bold text-main"
                                                                    placeholder="0.00" required>
                                                            </div>
                                                        </div>
                                                        <div class="mb-4">
                                                            <label
                                                                class="form-label extra-small fw-bold text-dim uppercase tracking-widest">Customer
                                                                Mobile</label>
                                                            <div
                                                                class="input-group input-group-lg border border-light rounded-3 overflow-hidden shadow-sm">
                                                                <span
                                                                    class="input-group-text bg-white border-0 text-muted ps-4"><i
                                                                        class="fi fi-rr-smartphone"></i></span>
                                                                <input type="text" name="mobile"
                                                                    class="form-control border-0 ps-2 fs-6 tracking-wide"
                                                                    placeholder="10-digit number">
                                                            </div>
                                                        </div>
                                                        <div class="mb-5">
                                                            <label
                                                                class="form-label extra-small fw-bold text-dim uppercase tracking-widest">Remark
                                                                (Optional)</label>
                                                            <div
                                                                class="input-group input-group-lg border border-light rounded-3 overflow-hidden shadow-sm">
                                                                <span
                                                                    class="input-group-text bg-white border-0 text-muted ps-4"><i
                                                                        class="fi fi-rr-comment"></i></span>
                                                                <input type="text" name="remark"
                                                                    class="form-control border-0 ps-2 fs-6 tracking-wide"
                                                                    placeholder="e.g. Service Fees">
                                                            </div>
                                                        </div>
                                                        <button type="submit"
                                                            class="btn btn-primary w-100 py-3 shadow-lg rounded-3 fw-bold fs-6 d-flex align-items-center justify-content-center gap-2 transition-all">
                                                            <i class="fi fi-rr-magic-wand"></i> Generate Link
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-lg-7" data-aos="fade-left" data-aos-delay="200">
                                            <div class="premium-card h-100 overflow-hidden d-flex flex-column">
                                                <div
                                                    class="p-4 border-bottom border-light bg-alt bg-opacity-50 d-flex align-items-center justify-content-between">
                                                    <h6 class="fw-bold text-main mb-0">Recent Links</h6>
                                                    <span
                                                        class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 extra-small fw-bold">
                                                        <%= payments ? payments.length : 0 %> Active
                                                    </span>
                                                </div>
                                                <div class="table-responsive flex-grow-1">
                                                    <table class="table-premium mb-0">
                                                        <thead>
                                                            <tr>
                                                                <th class="ps-4">Customer</th>
                                                                <th>Amount</th>
                                                                <th class="text-center">Status</th>
                                                                <th class="pe-4 text-end">Date</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <% if (payments && payments.length> 0) { %>
                                                                <% payments.forEach(payment=> { %>
                                                                    <tr
                                                                        class="align-middle transition-all hover-bg-alt">
                                                                        <td class="ps-4 py-3">
                                                                            <div
                                                                                class="d-flex align-items-center gap-3">
                                                                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center"
                                                                                    style="width: 36px; height: 36px;">
                                                                                    <i class="fi fi-rr-user fs-6"></i>
                                                                                </div>
                                                                                <div>
                                                                                    <div
                                                                                        class="small fw-bold text-main">
                                                                                        <%= payment.customer_mobile
                                                                                            || 'Guest' %>
                                                                                    </div>
                                                                                    <div class="extra-small text-muted text-truncate"
                                                                                        style="max-width: 150px;">
                                                                                        <%= payment.remark1
                                                                                            || 'No remark' %>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </td>
                                                                        <td class="fw-bold text-main fs-6">
                                                                            ₹<%= parseFloat(payment.amount).toFixed(2)
                                                                                %>
                                                                        </td>
                                                                        <td class="text-center">
                                                                            <span
                                                                                class="badge-premium <%= (payment.status == '1') ? 'badge-success bg-opacity-10 text-success border-success border-opacity-25' : 'badge-warning bg-opacity-10 text-warning border-warning border-opacity-25' %> extra-small fw-bold">
                                                                                <% if(payment.status=='1' ) { %>
                                                                                    <i
                                                                                        class="fi fi-rr-check-circle me-1"></i>
                                                                                    Paid
                                                                                    <% } else { %>
                                                                                        <i
                                                                                            class="fi fi-rr-time-fast me-1"></i>
                                                                                        Unpaid
                                                                                        <% } %>
                                                                            </span>
                                                                        </td>
                                                                        <td class="pe-4 text-end">
                                                                            <div class="small fw-semibold text-main">
                                                                                <%= new
                                                                                    Date(payment.created_on).toLocaleDateString('en-GB',
                                                                                    { day: '2-digit' , month: 'short' })
                                                                                    %>
                                                                            </div>
                                                                            <div class="extra-small text-dim">
                                                                                <%= new
                                                                                    Date(payment.created_on).toLocaleTimeString('en-GB',
                                                                                    { hour: '2-digit' ,
                                                                                    minute: '2-digit' }) %>
                                                                            </div>
                                                                        </td>
                                                                    </tr>
                                                                    <% }) %>
                                                                        <% } else { %>
                                                                            <tr>
                                                                                <td colspan="4"
                                                                                    class="text-center py-5">
                                                                                    <div
                                                                                        class="d-flex flex-column justify-content-center align-items-center py-4 my-2">
                                                                                        <div class="bg-alt rounded-circle d-flex align-items-center justify-content-center mb-3 text-dim shadow-sm border border-light"
                                                                                            style="width: 64px; height: 64px; font-size: 1.5rem;">
                                                                                            <i
                                                                                                class="fi fi-rr-link-slash"></i>
                                                                                        </div>
                                                                                        <h6
                                                                                            class="fw-bold text-main mb-1">
                                                                                            No Links Created</h6>
                                                                                        <p
                                                                                            class="small text-muted mb-0">
                                                                                            Generate your first payment
                                                                                            link to get started.</p>
                                                                                    </div>
                                                                                </td>
                                                                            </tr>
                                                                            <% } %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                        </div>
                </div>
        </div>
    </div>
    <%- include('../partials/footer') %>
</body>

</html>