<!DOCTYPE html>
<html>

<head>
    <%- include('../partials/head') %>
        <title>User List | Admin</title>
</head>

<body class="bg-mesh">
    <div class="container-fluid p-0">
        <div class="row g-0">
            <%- include('../partials/sidebar') %>
                <div class="col">
                    <%- include('../partials/header') %>

                        <div class="px-4 py-5" style="min-height: calc(100vh - 70px);">
                            <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-5 gap-4"
                                data-aos="fade-down">
                                <div>
                                    <h2 class="fw-bold mb-1 tracking-tight text-main">User List</h2>
                                    <p class="text-muted small mb-0">Manage all merchants utilizing your payment
                                        gateway.</p>
                                </div>
                                <div class="d-flex flex-wrap gap-3">
                                    <form action="/auth/merchant_list" method="GET" class="d-flex gap-2">
                                        <div class="input-group overflow-hidden bg-white rounded-3 shadow-sm border border-light"
                                            style="max-width: 300px;">
                                            <span class="input-group-text bg-white border-0 text-muted ps-3"><i
                                                    class="fi fi-rr-search"></i></span>
                                            <input type="text" name="search"
                                                class="form-control border-0 ps-2 fs-6 tracking-wide"
                                                placeholder="Search users..." value="<%= search || '' %>">
                                        </div>
                                        <button type="submit"
                                            class="btn btn-alt px-4 rounded-3 fw-bold d-none d-sm-block">Search</button>
                                    </form>
                                    <a href="/auth/add_user"
                                        class="btn btn-premium px-4 py-2 shadow-sm rounded-3 d-flex align-items-center gap-2">
                                        <i class="fi fi-rr-user-add"></i> Create User
                                    </a>
                                </div>
                            </div>

                            <div class="premium-card overflow-hidden" data-aos="fade-up" data-aos-delay="100">
                                <div class="table-responsive">
                                    <table class="table-premium mb-0">
                                        <thead>
                                            <tr>
                                                <th class="ps-4">User ID</th>
                                                <th>Merchant Info</th>
                                                <th>Contact</th>
                                                <th>Email Address</th>
                                                <th>Account Status</th>
                                                <th class="text-end pe-4">Manage</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if(merchants && merchants.length> 0) { %>
                                                <% merchants.forEach(m=> { %>
                                                    <tr class="align-middle transition-all hover-bg">
                                                        <td class="ps-4">
                                                            <div class="d-flex align-items-center gap-2">
                                                                <i class="fi fi-rr-fingerprint text-dim small"></i>
                                                                <span class="fw-bold text-main font-monospace small">#
                                                                    <%= m.id.substring(0,8) %></span>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div class="d-flex align-items-center gap-3">
                                                                <div class="bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center shadow-sm"
                                                                    style="width: 40px; height: 40px; border-radius: 12px; font-size: 1rem; font-weight: 700;">
                                                                    <%= (m.name || 'U' ).substring(0,1).toUpperCase() %>
                                                                </div>
                                                                <div>
                                                                    <div class="fw-bold text-main small">
                                                                        <%= m.name %>
                                                                    </div>
                                                                    <div
                                                                        class="extra-small text-dim d-flex align-items-center gap-1">
                                                                        <i
                                                                            class="fi fi-rr-building text-opacity-50"></i>
                                                                        <%= m.company || 'Individual' %>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div
                                                                class="d-flex align-items-center gap-2 small fw-bold text-main">
                                                                <i class="fi fi-rr-smartphone text-dim"></i>
                                                                <%= m.mobile %>
                                                            </div>
                                                        </td>
                                                        <td class="small text-muted">
                                                            <%= m.email %>
                                                        </td>
                                                        <td>
                                                            <% if(new Date(m.expiry)> new Date()) { %>
                                                                <span
                                                                    class="badge-premium badge-success shadow-sm d-inline-flex align-items-center gap-1">
                                                                    <div class="status-indicator bg-success"></div>
                                                                    Active
                                                                </span>
                                                                <% } else { %>
                                                                    <span
                                                                        class="badge-premium badge-danger shadow-sm d-inline-flex align-items-center gap-1 opacity-75">
                                                                        <div class="status-indicator bg-danger"></div>
                                                                        Expired
                                                                    </span>
                                                                    <% } %>
                                                        </td>
                                                        <td class="text-end pe-4">
                                                            <div class="d-flex justify-content-end gap-2">
                                                                <a href="/auth/edituser?mobile=<%= m.mobile %>"
                                                                    class="btn btn-alt p-2 rounded-3 text-primary bg-primary bg-opacity-10 hover-scale"
                                                                    title="Edit User">
                                                                    <i class="fi fi-rr-edit"></i>
                                                                </a>
                                                                <button
                                                                    class="btn btn-alt p-2 rounded-3 text-danger bg-danger bg-opacity-10 hover-scale"
                                                                    title="Delete User">
                                                                    <i class="fi fi-rr-trash"></i>
                                                                </button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                                        <% } else { %>
                                                            <tr>
                                                                <td colspan="6" class="text-center py-5">
                                                                    <div
                                                                        class="d-flex flex-column align-items-center justify-content-center opacity-50">
                                                                        <i class="fi fi-rr-users-alt mb-3 text-dim"
                                                                            style="font-size: 3rem;"></i>
                                                                        <h6 class="fw-bold text-main">No merchants found
                                                                        </h6>
                                                                        <p class="extra-small text-muted">Try adjusting
                                                                            your search or add a new user.</p>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                </div>
        </div>
    </div>
    <%- include('../partials/footer') %>
</body>

</html>