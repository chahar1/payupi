<%- include('../partials/head') %>

    <body class="bg-mesh">
        <div class="container-fluid p-0">
            <div class="row g-0 justify-content-center align-items-center vh-100">
                <div class="col-md-5 fade-in">
                    <div class="premium-card p-4 p-lg-5">
                        <div class="text-center mb-4">
                            <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 rounded-circle mb-3"
                                style="width: 64px; height: 64px;">
                                <i class="fas fa-university text-primary fs-3"></i>
                            </div>
                            <h4 class="fw-bold text-main mb-1">Verify HDFC Setup</h4>
                            <p class="text-muted small">Link your HDFC Vyapar merchant account</p>
                        </div>

                        <form method="POST" action="/auth/hdfc">
                            <div class="mb-3">
                                <label for="OTP"
                                    class="form-label extra-small fw-bold text-dim uppercase tracking-widest">One-Time
                                    Password</label>
                                <input type="number" name="OTP" id="OTP" placeholder="Enter 6-digit OTP"
                                    class="form-control form-control-premium text-center" required>
                            </div>
                            <div class="mb-3">
                                <label for="PIN"
                                    class="form-label extra-small fw-bold text-dim uppercase tracking-widest">UPI
                                    PIN</label>
                                <input type="password" name="PIN" id="PIN" placeholder="Enter secure PIN"
                                    class="form-control form-control-premium" required>
                            </div>
                            <div class="mb-4">
                                <label for="upi"
                                    class="form-label extra-small fw-bold text-dim uppercase tracking-widest">HDFC UPI
                                    ID</label>
                                <input type="text" name="upi" id="upi" placeholder="e.g. merchant@hdfc"
                                    value="<%= merchant ? merchant.hdfc_upi_id : '' %>"
                                    class="form-control form-control-premium" required>
                            </div>

                            <div class="mb-3">
                                <label for="number"
                                    class="form-label extra-small fw-bold text-dim uppercase tracking-widest">Mobile
                                    Number</label>
                                <input type="number" name="number" id="number" placeholder="Enter Mobile"
                                    value="<%= merchant ? merchant.hdfc_number : '' %>"
                                    class="form-control form-control-premium" required>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-premium py-3">Link Gateway</button>
                                <a href="/auth/connect_merchant"
                                    class="btn btn-link text-muted text-decoration-none small">Go Back</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <%- include('../partials/footer') %>
    </body>

    </html>