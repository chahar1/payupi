<%- include('../partials/head') %>

    <body class="bg-mesh">
        <div class="container-fluid p-0">
            <div class="row g-0 justify-content-center align-items-center vh-100">
                <div class="col-md-5 fade-in">
                    <div class="premium-card p-4 p-lg-5">
                        <div class="text-center mb-4">
                            <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 rounded-circle mb-3"
                                style="width: 64px; height: 64px;">
                                <i class="fas fa-mobile-alt text-primary fs-3"></i>
                            </div>
                            <h4 class="fw-bold text-main mb-1">Verify PhonePe</h4>
                            <p class="text-muted small">Connect your PhonePe merchant account via OTP</p>
                        </div>

                        <% if (alreadyActive) { %>
                            <div class="alert alert-info border-0 bg-info bg-opacity-10 text-info small mb-4">
                                <i class="fas fa-info-circle me-2"></i> Merchant already connected!
                            </div>
                            <div class="d-grid">
                                <a href="/auth/connect_merchant" class="btn btn-premium py-3">Go Back</a>
                            </div>
                            <% } else { %>
                                <% if (error) { %>
                                    <div
                                        class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger small mb-4">
                                        <i class="fas fa-exclamation-circle me-2"></i>
                                        <%= error %>
                                    </div>
                                    <% } %>

                                        <form method="POST" action="/auth/phonepe">
                                            <div class="mb-4">
                                                <label for="phonepe_mobile"
                                                    class="form-label extra-small fw-bold text-dim uppercase tracking-widest">PhonePe
                                                    Mobile Number</label>
                                                <div class="input-group">
                                                    <span class="input-group-text border-0 bg-light"><i
                                                            class="fas fa-phone text-muted mt-1"></i></span>
                                                    <input type="number" name="phonepe_mobile" id="phonepe_mobile"
                                                        placeholder="Enter 10-digit number"
                                                        class="form-control form-control-premium" required
                                                        minlength="10" maxlength="10"
                                                        value="<%= merchant ? merchant.phonepe_number : '' %>">
                                                </div>
                                            </div>
                                            <div class="d-grid gap-2">
                                                <button type="submit" class="btn btn-premium py-3">Send OTP</button>
                                                <a href="/auth/connect_merchant"
                                                    class="btn btn-link text-muted text-decoration-none small">Cancel</a>
                                            </div>
                                        </form>
                                        <% } %>
                    </div>
                </div>
            </div>
        </div>
        <%- include('../partials/footer') %>
    </body>

    </html>