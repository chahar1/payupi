<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
        <title>Create Account – Paybilupi</title>
        <style>
            :root {
                --primary: #4f46e5;
                --primary-d: #3730a3;
                --primary-light: #eef2ff;
                --text: #0f172a;
                --muted: #64748b;
                --border: #e2e8f0;
                --surface: #f8fafc;
            }

            body {
                background: #ffffff;
                color: var(--text);
                min-height: 100vh;
                margin: 0;
            }

            /* ── Layout ── */
            .reg-layout {
                min-height: 100vh;
                display: flex;
            }

            /* Left panel */
            .reg-left {
                width: 42%;
                background: linear-gradient(155deg, #4f46e5 0%, #7c3aed 60%, #6d28d9 100%);
                position: sticky;
                top: 0;
                height: 100vh;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                padding: 52px 56px;
                overflow: hidden;
            }

            .reg-left::before {
                content: '';
                position: absolute;
                top: -100px;
                right: -100px;
                width: 350px;
                height: 350px;
                background: rgba(255, 255, 255, .07);
                border-radius: 50%;
            }

            .reg-left::after {
                content: '';
                position: absolute;
                bottom: -80px;
                left: -80px;
                width: 260px;
                height: 260px;
                background: rgba(255, 255, 255, .05);
                border-radius: 50%;
            }

            .brand-logo {
                display: flex;
                align-items: center;
                gap: 10px;
                text-decoration: none;
                position: relative;
                z-index: 1;
            }

            .brand-logo .icon-box {
                width: 38px;
                height: 38px;
                background: rgba(255, 255, 255, .2);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                border: 1px solid rgba(255, 255, 255, .3);
            }

            .brand-logo span {
                font-weight: 800;
                font-size: 1.2rem;
                color: #fff;
                letter-spacing: -.03em;
            }

            .left-content {
                position: relative;
                z-index: 1;
            }

            .left-tagline {
                font-size: clamp(1.5rem, 2.5vw, 2rem);
                font-weight: 800;
                color: #fff;
                letter-spacing: -.03em;
                line-height: 1.2;
                margin-bottom: 16px;
            }

            .left-sub {
                font-size: .9rem;
                color: rgba(255, 255, 255, .7);
                line-height: 1.7;
                margin-bottom: 36px;
            }

            .left-stat {
                display: flex;
                gap: 32px;
            }

            .left-stat .s-item {
                text-align: center;
            }

            .left-stat .s-val {
                font-size: 1.4rem;
                font-weight: 900;
                color: #fff;
                letter-spacing: -.02em;
                line-height: 1;
            }

            .left-stat .s-lbl {
                font-size: .7rem;
                color: rgba(255, 255, 255, .55);
                text-transform: uppercase;
                letter-spacing: .08em;
                margin-top: 4px;
                font-weight: 600;
            }

            .left-testimonial {
                background: rgba(255, 255, 255, .1);
                border: 1px solid rgba(255, 255, 255, .15);
                border-radius: 16px;
                padding: 20px 22px;
                position: relative;
                z-index: 1;
            }

            .left-testimonial p {
                font-size: .85rem;
                color: rgba(255, 255, 255, .85);
                line-height: 1.65;
                margin: 0 0 14px;
            }

            .left-testimonial .author {
                font-size: .78rem;
                font-weight: 700;
                color: #fff;
            }

            .left-testimonial .role {
                font-size: .72rem;
                color: rgba(255, 255, 255, .5);
            }

            .t-stars {
                color: #fbbf24;
                font-size: .8rem;
                letter-spacing: 2px;
                margin-bottom: 10px;
            }

            /* Right panel */
            .reg-right {
                flex: 1;
                overflow-y: auto;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 48px 40px;
                background: #fff;
            }

            .form-container {
                width: 100%;
                max-width: 540px;
            }

            .form-header {
                margin-bottom: 36px;
            }

            .form-header h1 {
                font-size: 1.75rem;
                font-weight: 800;
                letter-spacing: -.03em;
                color: var(--text);
                margin-bottom: 8px;
                line-height: 1.2;
            }

            .form-header p {
                font-size: .875rem;
                color: var(--muted);
                line-height: 1.6;
            }

            /* Step indicator */
            .steps-bar {
                display: flex;
                align-items: center;
                gap: 0;
                margin-bottom: 32px;
            }

            .step-item {
                display: flex;
                align-items: center;
                gap: 8px;
                flex: 1;
            }

            .step-circle {
                width: 28px;
                height: 28px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: .72rem;
                font-weight: 700;
                flex-shrink: 0;
            }

            .step-circle.active {
                background: var(--primary);
                color: #fff;
            }

            .step-circle.done {
                background: #10b981;
                color: #fff;
            }

            .step-circle.idle {
                background: var(--surface);
                color: var(--muted);
                border: 1.5px solid var(--border);
            }

            .step-label {
                font-size: .72rem;
                font-weight: 600;
                color: var(--muted);
                white-space: nowrap;
            }

            .step-line {
                flex: 1;
                height: 2px;
                background: var(--border);
                margin: 0 8px;
            }

            /* Form fields */
            .field-group {
                margin-bottom: 20px;
            }

            .field-label {
                display: block;
                font-size: .72rem;
                font-weight: 700;
                letter-spacing: .09em;
                text-transform: uppercase;
                color: var(--muted);
                margin-bottom: 7px;
            }

            .field-wrap {
                position: relative;
            }

            .field-wrap .f-icon {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--muted);
                font-size: .95rem;
                pointer-events: none;
            }

            .field-wrap input {
                width: 100%;
                padding: 12px 14px 12px 42px;
                border: 1.5px solid var(--border);
                border-radius: 10px;
                font-size: .9rem;
                font-family: 'Outfit', sans-serif;
                color: var(--text);
                background: #fff;
                outline: none;
                transition: border-color .2s, box-shadow .2s;
            }

            .field-wrap input::placeholder {
                color: #cbd5e1;
            }

            .field-wrap input:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(79, 70, 229, .1);
            }

            .field-wrap input:valid:not(:placeholder-shown) {
                border-color: #10b981;
            }

            /* Submit button */
            .btn-submit {
                width: 100%;
                padding: 15px;
                background: linear-gradient(135deg, var(--primary) 0%, #7c3aed 100%);
                color: #fff;
                border: none;
                border-radius: 12px;
                font-size: 1rem;
                font-weight: 700;
                font-family: 'Outfit', sans-serif;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                box-shadow: 0 4px 14px rgba(79, 70, 229, .35);
                transition: transform .2s, box-shadow .2s;
                letter-spacing: -.01em;
            }

            .btn-submit:hover {
                transform: translateY(-1px);
                box-shadow: 0 8px 24px rgba(79, 70, 229, .45);
            }

            /* Trust badges */
            .trust-badges {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 20px;
                margin-top: 20px;
                flex-wrap: wrap;
            }

            .t-badge {
                display: flex;
                align-items: center;
                gap: 5px;
                font-size: .72rem;
                color: var(--muted);
                font-weight: 500;
            }

            /* Section divider */
            .or-divider {
                display: flex;
                align-items: center;
                gap: 12px;
                margin: 20px 0;
            }

            .or-divider span {
                font-size: .78rem;
                color: var(--muted);
                white-space: nowrap;
            }

            .or-line {
                flex: 1;
                height: 1px;
                background: var(--border);
            }

            /* 2-col row */
            .field-row {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 16px;
            }

            /* Error alert */
            .err-alert {
                background: #fef2f2;
                border: 1px solid #fecaca;
                border-radius: 10px;
                padding: 12px 16px;
                font-size: .85rem;
                color: #dc2626;
                display: flex;
                align-items: center;
                gap: 8px;
                margin-bottom: 20px;
            }

            /* Mobile responsive */
            @media (max-width: 900px) {
                .reg-left {
                    display: none;
                }

                .reg-right {
                    padding: 32px 24px;
                }
            }
        </style>
</head>

<body>
    <div class="reg-layout">

        <!-- ── Left Panel ── -->
        <div class="reg-left d-none d-lg-flex flex-column justify-content-between">
            <!-- Brand -->
            <a href="/" class="brand-logo">
                <div class="icon-box"><i class="fi fi-rr-wallet text-white fs-6 mt-1"></i></div>
                <span>Paybilupi</span>
            </a>

            <!-- Main pitch -->
            <div class="left-content">
                <h2 class="left-tagline">Start accepting<br>payments today.<br>For free.</h2>
                <p class="left-sub">Join thousands of Indian merchants using Paybilupi to collect UPI payments with zero
                    fees and instant settlements.</p>

                <div class="left-stat mb-4">
                    <div class="s-item">
                        <div class="s-val">0%</div>
                        <div class="s-lbl">Processing Fee</div>
                    </div>
                    <div class="s-item">
                        <div class="s-val">&lt; 2s</div>
                        <div class="s-lbl">Settlement</div>
                    </div>
                    <div class="s-item">
                        <div class="s-val">5K+</div>
                        <div class="s-lbl">Merchants</div>
                    </div>
                </div>

                <!-- Testimonial -->
                <div class="left-testimonial">
                    <div class="t-stars">★★★★★</div>
                    <p>"Switched from Razorpay and saved ₹18,000 in fees the very first month. Onboarding took under 10
                        minutes."</p>
                    <div class="author">Rahul Sharma</div>
                    <div class="role">E-commerce Founder, Delhi</div>
                </div>
            </div>

            <!-- Footer -->
            <p style="color:rgba(255,255,255,.35);font-size:.75rem;position:relative;z-index:1;">
                © <%= new Date().getFullYear() %> Paybilupi Technologies Pvt. Ltd.
            </p>
        </div>

        <!-- ── Right Panel (Form) ── -->
        <div class="reg-right">
            <div class="form-container">

                <!-- Header -->
                <div class="form-header">
                    <!-- Mobile brand -->
                    <a href="/" class="d-flex d-lg-none align-items-center gap-2 text-decoration-none mb-4">
                        <div
                            style="width:32px;height:32px;background:var(--primary);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                            <i class="fi fi-rr-wallet text-white" style="font-size:.85rem;margin-top:2px;"></i>
                        </div>
                        <span
                            style="font-weight:800;font-size:1.1rem;color:var(--text);letter-spacing:-.02em;">Paybilupi</span>
                    </a>

                    <h1>Create your account</h1>
                    <p>Get started for free. No credit card required.</p>
                </div>

                <!-- Step indicators -->
                <div class="steps-bar">
                    <div class="step-item">
                        <div class="step-circle active">1</div>
                        <div class="step-label">Account Info</div>
                    </div>
                    <div class="step-line"></div>
                    <div class="step-item">
                        <div class="step-circle idle">2</div>
                        <div class="step-label">Verification</div>
                    </div>
                    <div class="step-line"></div>
                    <div class="step-item">
                        <div class="step-circle idle">3</div>
                        <div class="step-label">Connect Wallet</div>
                    </div>
                </div>

                <!-- Error -->
                <% if (error) { %>
                    <div class="err-alert">
                        <i class="fi fi-rr-info"></i>
                        <%= error %>
                    </div>
                    <% } %>

                        <!-- Form -->
                        <form method="POST" action="/auth/register">

                            <div class="field-row">
                                <!-- Full Name -->
                                <div class="field-group">
                                    <label class="field-label">Full Name</label>
                                    <div class="field-wrap">
                                        <i class="fi fi-rr-user f-icon"></i>
                                        <input type="text" name="name" placeholder="John Doe" required>
                                    </div>
                                </div>
                                <!-- WhatsApp -->
                                <div class="field-group">
                                    <label class="field-label">WhatsApp Number</label>
                                    <div class="field-wrap">
                                        <i class="fi fi-rr-phone-call f-icon"></i>
                                        <input type="tel" name="mobile" placeholder="9876543210" maxlength="10"
                                            required>
                                    </div>
                                </div>
                            </div>

                            <!-- Email -->
                            <div class="field-group">
                                <label class="field-label">Email Address</label>
                                <div class="field-wrap">
                                    <i class="fi fi-rr-envelope f-icon"></i>
                                    <input type="email" name="email" placeholder="john@example.com" required>
                                </div>
                            </div>

                            <!-- Company -->
                            <div class="field-group">
                                <label class="field-label">Business / Company Name</label>
                                <div class="field-wrap">
                                    <i class="fi fi-rr-building f-icon"></i>
                                    <input type="text" name="company" placeholder="Acme Pvt. Ltd." required>
                                </div>
                            </div>

                            <div class="field-row">
                                <!-- Aadhaar -->
                                <div class="field-group">
                                    <label class="field-label">Aadhaar Number</label>
                                    <div class="field-wrap">
                                        <i class="fi fi-rr-id-badge f-icon"></i>
                                        <input type="text" name="aadhaar" placeholder="1234 5678 9012" maxlength="12"
                                            required>
                                    </div>
                                </div>
                                <!-- PAN -->
                                <div class="field-group">
                                    <label class="field-label">PAN Number</label>
                                    <div class="field-wrap">
                                        <i class="fi fi-rr-credit-card f-icon"></i>
                                        <input type="text" name="pan" placeholder="ABCDE1234F" maxlength="10" required>
                                    </div>
                                </div>
                            </div>

                            <!-- Password -->
                            <div class="field-group">
                                <label class="field-label">Password</label>
                                <div class="field-wrap">
                                    <i class="fi fi-rr-lock f-icon"></i>
                                    <input type="password" name="password" placeholder="Min. 8 characters" required>
                                </div>
                            </div>

                            <!-- Terms note -->
                            <p style="font-size:.75rem;color:var(--muted);margin-bottom:20px;line-height:1.6;">
                                By creating an account, you agree to our
                                <a href="/terms"
                                    style="color:var(--primary);text-decoration:none;font-weight:600;">Terms of
                                    Service</a> and
                                <a href="/privacy"
                                    style="color:var(--primary);text-decoration:none;font-weight:600;">Privacy
                                    Policy</a>.
                            </p>

                            <button type="submit" class="btn-submit">
                                Create Free Account <i class="fi fi-rr-arrow-right"></i>
                            </button>
                        </form>

                        <!-- Trust badges -->
                        <div class="trust-badges">
                            <span class="t-badge"><i class="fi fi-rr-shield-check" style="color:#10b981;"></i> PCI-DSS
                                Secure</span>
                            <span class="t-badge"><i class="fi fi-rr-lock" style="color:#4f46e5;"></i> Encrypted</span>
                            <span class="t-badge"><i class="fi fi-rr-bolt" style="color:#f59e0b;"></i> Instant
                                Setup</span>
                        </div>

                        <!-- Login link -->
                        <p style="text-align:center;font-size:.85rem;color:var(--muted);margin-top:28px;">
                            Already have an account?
                            <a href="/auth/login"
                                style="color:var(--primary);font-weight:700;text-decoration:none;">Sign in →</a>
                        </p>

            </div>
        </div>
    </div>
</body>

</html>