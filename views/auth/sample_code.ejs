                                                type="button" role="tab" aria-controls="nodejs" aria-selected="true"
                                                onclick="updateNavStyles(this)"><i
                                                    class="fab fa-node-js text-success me-1"></i> Node.js</button>
                                        </li>
                                        <li class="nav-item" role="presentation">
