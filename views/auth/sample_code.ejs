                            <div class="d-flex align-items-center mb-4 slide-up">
                                <h5 class="fw-bold mb-0 text-main d-flex align-items-center gap-2">
                                    <i class="fi fi-rr-code-simple text-primary"></i> Integration Examples
                                </h5>
                            </div>

                            <div class="premium-card p-0 overflow-hidden slide-up border border-light shadow-sm">
                                <div
